{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mergeos.shop/protocol/airdrop-missions.v1.schema.json",
  "title": "MergeOS Airdrop Missions v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["protocol_version", "kind", "missions", "stats"],
  "properties": {
    "protocol_version": { "const": "mergeos.airdrop-missions.v1" },
    "kind": { "const": "airdrop_missions" },
    "missions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "title",
          "description",
          "proof_requirement",
          "required_reference",
          "default_allocation_mrg",
          "max_allocation_mrg",
          "mission_score",
          "proof_signals"
        ],
        "properties": {
          "id": { "type": "string", "minLength": 2, "maxLength": 80 },
          "title": { "type": "string", "minLength": 2, "maxLength": 120 },
          "description": { "type": "string", "minLength": 8, "maxLength": 280 },
          "proof_requirement": { "type": "string", "minLength": 8, "maxLength": 280 },
          "required_reference": { "enum": ["task_or_url", "task_reference", "proof_url"] },
          "default_allocation_mrg": { "type": "integer", "minimum": 1, "maximum": 100000 },
          "max_allocation_mrg": { "type": "integer", "minimum": 1, "maximum": 100000 },
          "mission_score": { "type": "integer", "minimum": 1, "maximum": 100 },
          "proof_signals": {
            "type": "array",
            "minItems": 1,
            "maxItems": 12,
            "items": { "type": "string", "minLength": 2, "maxLength": 80 }
          }
        }
      }
    },
    "stats": {
      "type": "object",
      "additionalProperties": { "type": "integer", "minimum": 0 },
      "required": ["mission_count", "default_allocation_mrg", "max_allocation_mrg", "average_mission_score"],
      "properties": {
        "mission_count": { "type": "integer", "minimum": 1 },
        "default_allocation_mrg": { "type": "integer", "minimum": 1 },
        "max_allocation_mrg": { "type": "integer", "minimum": 1 },
        "average_mission_score": { "type": "integer", "minimum": 1, "maximum": 100 }
      }
    }
  }
}
