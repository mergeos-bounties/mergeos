{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mergeos.shop/protocol/wallet-migration.v1.schema.json",
  "title": "MergeOS Wallet Migration v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "protocol_version",
    "kind",
    "migration_id",
    "status",
    "legacy_chain",
    "legacy_address",
    "legacy_address_hash",
    "target_chain",
    "target_address",
    "target_account",
    "token_symbol",
    "required_proofs",
    "contract",
    "wallet",
    "created_at"
  ],
  "properties": {
    "protocol_version": { "const": "mergeos.wallet-migration.v1" },
    "kind": { "const": "wallet_migration" },
    "migration_id": { "type": "string", "minLength": 5, "maxLength": 80 },
    "status": { "enum": ["linked", "pending_contract_registration", "registered", "failed"] },
    "legacy_chain": { "enum": ["trc20", "evm"] },
    "legacy_address": { "type": "string", "minLength": 1, "maxLength": 120 },
    "legacy_address_hash": { "type": "string", "minLength": 64, "maxLength": 64 },
    "target_chain": { "const": "solana" },
    "target_address": { "type": "string", "minLength": 32, "maxLength": 96 },
    "target_account": { "type": "string", "minLength": 32, "maxLength": 96 },
    "token_symbol": { "type": "string", "minLength": 1, "maxLength": 16 },
    "required_proofs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "enum": [
          "legacy_wallet_ownership_signature",
          "anchor_register_legacy_wallet_transaction"
        ]
      }
    },
    "contract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["network", "program_id", "program_ready", "instruction", "pda_seeds", "pda_seed_formats", "args"],
      "properties": {
        "network": { "enum": ["mainnet-beta", "devnet", "testnet", "localnet"] },
        "program_id": { "type": "string", "maxLength": 96 },
        "program_ready": { "type": "boolean" },
        "instruction": { "const": "register_legacy_wallet" },
        "pda_seeds": {
          "type": "array",
          "minItems": 3,
          "items": { "type": "string", "minLength": 1, "maxLength": 96 }
        },
        "pda_seed_formats": {
          "type": "array",
          "minItems": 3,
          "items": {
            "enum": [
              "utf8",
              "bytes32:hex_decode(contract.args.legacy_address_hash)"
            ]
          }
        },
        "args": {
          "type": "object",
          "additionalProperties": false,
          "required": ["legacy_chain", "legacy_address_hash", "solana_wallet"],
          "properties": {
            "legacy_chain": { "enum": ["trc20", "evm"] },
            "legacy_address_hash": { "type": "string", "minLength": 64, "maxLength": 64 },
            "solana_wallet": { "type": "string", "minLength": 32, "maxLength": 96 }
          }
        },
        "token_mint": { "type": "string", "maxLength": 96 },
        "treasury_receiver": { "type": "string", "maxLength": 96 }
      }
    },
    "wallet": {
      "type": "object",
      "additionalProperties": true,
      "required": ["address", "account", "chain", "owner_linked", "created_at"],
      "properties": {
        "address": { "type": "string", "minLength": 32, "maxLength": 96 },
        "account": { "type": "string", "minLength": 32, "maxLength": 96 },
        "chain": { "const": "solana" },
        "legacy_address": { "type": "string", "maxLength": 120 },
        "balance_cents": { "type": "integer" },
        "received_cents": { "type": "integer" },
        "sent_cents": { "type": "integer" },
        "transaction_count": { "type": "integer", "minimum": 0 },
        "linked_accounts": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "owner_linked": { "type": "boolean" },
        "created_at": { "type": "string", "format": "date-time" },
        "linked_at": { "type": "string", "format": "date-time" }
      }
    },
    "created_at": { "type": "string", "format": "date-time" }
  }
}
