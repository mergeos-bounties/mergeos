{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mergeos.shop/protocol/agent-queue.v1.schema.json",
  "title": "MergeOS Agent Queue v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["protocol_version", "kind", "stats", "agents", "tasks"],
  "properties": {
    "protocol_version": { "const": "mergeos.agent-queue.v1" },
    "kind": { "const": "agent_queue" },
    "stats": {
      "type": "object",
      "additionalProperties": false,
      "required": ["total_count", "agent_count", "ready_count", "reward_cents", "token_symbol"],
      "properties": {
        "total_count": { "type": "integer", "minimum": 0 },
        "agent_count": { "type": "integer", "minimum": 0 },
        "ready_count": { "type": "integer", "minimum": 0 },
        "reward_cents": { "type": "integer", "minimum": 0 },
        "token_symbol": { "type": "string", "minLength": 1, "maxLength": 16 },
        "updated_at": { "type": "string", "format": "date-time" }
      }
    },
    "agents": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "title", "worker_kind", "task_count", "open_task_count", "budget_cents", "status", "supported_actions", "queue_depth"],
        "properties": {
          "type": { "type": "string", "minLength": 1, "maxLength": 120 },
          "title": { "type": "string", "minLength": 1, "maxLength": 160 },
          "worker_kind": { "enum": ["human", "agent", "hybrid"] },
          "role": { "enum": ["ceo_planner", "subagent"] },
          "parent_agent_type": { "type": "string", "maxLength": 120 },
          "subagent_types": {
            "type": "array",
            "items": { "type": "string", "minLength": 1, "maxLength": 120 }
          },
          "delegation_endpoint": { "type": "string", "maxLength": 240 },
          "focus": {
            "type": "array",
            "items": { "type": "string", "minLength": 1, "maxLength": 120 }
          },
          "task_count": { "type": "integer", "minimum": 0 },
          "open_task_count": { "type": "integer", "minimum": 0 },
          "budget_cents": { "type": "integer", "minimum": 0 },
          "status": { "enum": ["active", "standby"] },
          "supported_actions": {
            "type": "array",
            "items": { "enum": ["review", "test", "generate", "deploy", "scan"] }
          },
          "queue_depth": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "tasks": {
      "type": "array",
      "items": { "$ref": "#/$defs/queueTask" }
    }
  },
  "$defs": {
    "queueTask": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "bounty_id",
        "project_id",
        "project_title",
        "issue_number",
        "title",
        "summary",
        "reward_cents",
        "worker_kind",
        "readiness",
        "evidence_required",
        "claim_endpoint",
        "action_endpoint",
        "protocol_url",
        "work_packet"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1, "maxLength": 120 },
        "bounty_id": { "type": "string", "minLength": 1, "maxLength": 120 },
        "project_id": { "type": "string", "minLength": 1, "maxLength": 96 },
        "project_title": { "type": "string", "minLength": 1, "maxLength": 240 },
        "issue_number": { "type": "integer", "minimum": 0 },
        "title": { "type": "string", "minLength": 1, "maxLength": 240 },
        "summary": { "type": "string", "minLength": 1, "maxLength": 1000 },
        "reward_cents": { "type": "integer", "minimum": 0 },
        "worker_kind": { "enum": ["human", "agent", "hybrid"] },
        "agent_type": { "type": "string", "maxLength": 120 },
        "readiness": { "enum": ["agent_ready", "hybrid_ready", "blocked"] },
        "evidence_required": {
          "type": "array",
          "items": { "type": "string", "minLength": 1, "maxLength": 120 }
        },
        "claim_endpoint": { "type": "string", "minLength": 1, "maxLength": 240 },
        "action_endpoint": { "type": "string", "minLength": 1, "maxLength": 240 },
        "protocol_url": { "type": "string", "minLength": 1, "maxLength": 512 },
        "work_packet": { "$ref": "#/$defs/workPacket" }
      }
    },
    "workPacket": {
      "type": "object",
      "additionalProperties": false,
      "required": ["claim_endpoint", "action_endpoint", "submit_endpoint", "context_urls", "runbook", "action_payloads"],
      "properties": {
        "claim_endpoint": { "type": "string", "minLength": 1, "maxLength": 240 },
        "action_endpoint": { "type": "string", "minLength": 1, "maxLength": 240 },
        "submit_endpoint": { "type": "string", "minLength": 1, "maxLength": 240 },
        "supervisor_agent_type": { "type": "string", "maxLength": 120 },
        "subagent_type": { "type": "string", "maxLength": 120 },
        "design_review_agent": { "type": "string", "maxLength": 120 },
        "delegation_chain": {
          "type": "array",
          "items": { "type": "string", "minLength": 1, "maxLength": 120 }
        },
        "context_urls": {
          "type": "object",
          "additionalProperties": true
        },
        "runbook": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/runbookStep" }
        },
        "action_payloads": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/actionPayload" }
        }
      }
    },
    "runbookStep": {
      "type": "object",
      "additionalProperties": false,
      "required": ["step", "action", "label", "method", "endpoint"],
      "properties": {
        "step": { "type": "integer", "minimum": 1 },
        "action": { "type": "string", "minLength": 1, "maxLength": 120 },
        "label": { "type": "string", "minLength": 1, "maxLength": 160 },
        "method": { "enum": ["GET", "POST", "PATCH", "DELETE"] },
        "endpoint": { "type": "string", "minLength": 1, "maxLength": 512 }
      }
    },
    "actionPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action", "label", "method", "endpoint", "body"],
      "properties": {
        "action": { "enum": ["review", "test", "generate", "deploy", "scan"] },
        "label": { "type": "string", "minLength": 1, "maxLength": 160 },
        "method": { "enum": ["POST"] },
        "endpoint": { "type": "string", "minLength": 1, "maxLength": 240 },
        "body": {
          "type": "object",
          "additionalProperties": true
        }
      }
    }
  }
}
