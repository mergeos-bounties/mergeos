{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mergeos.shop/protocol/ai-workflow.v1.schema.json",
  "title": "MergeOS AI Workflow v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["protocol_version", "kind", "project_id", "project_title", "status", "progress", "task_count", "agent_task_count", "human_task_count", "hybrid_task_count", "ai_action_count", "updated_at", "stages", "signals"],
  "properties": {
    "protocol_version": { "const": "mergeos.ai-workflow.v1" },
    "kind": { "const": "ai_workflow" },
    "project_id": { "type": "string", "minLength": 1, "maxLength": 96 },
    "project_title": { "type": "string", "maxLength": 240 },
    "status": { "enum": ["queued", "orchestrating", "ready"] },
    "progress": { "type": "integer", "minimum": 0, "maximum": 100 },
    "current_step": {
      "enum": [
        "repo_import",
        "issue_scan",
        "task_generation",
        "reward_estimation",
        "contributor_routing",
        "pr_review",
        "deployment_validation"
      ]
    },
    "task_count": { "type": "integer", "minimum": 0 },
    "agent_task_count": { "type": "integer", "minimum": 0 },
    "human_task_count": { "type": "integer", "minimum": 0 },
    "hybrid_task_count": { "type": "integer", "minimum": 0 },
    "ai_action_count": { "type": "integer", "minimum": 0 },
    "updated_at": { "type": "string", "format": "date-time" },
    "stages": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "title", "body", "status", "tone", "actor_lane", "artifact_kind", "output_endpoint", "output_protocol", "output_protocol_url", "context_urls", "checklist", "produced_count", "updated_at"],
        "properties": {
          "id": {
            "enum": [
              "repo_import",
              "issue_scan",
              "task_generation",
              "reward_estimation",
              "contributor_routing",
              "pr_review",
              "deployment_validation"
            ]
          },
          "title": { "type": "string", "minLength": 1, "maxLength": 160 },
          "body": { "type": "string", "maxLength": 1000 },
          "status": { "enum": ["pending", "in_progress", "complete"] },
          "tone": { "enum": ["amber", "blue", "green"] },
          "actor_lane": { "enum": ["system", "ai", "human", "hybrid", "deployment_agent"] },
          "artifact_kind": {
            "enum": [
              "repository_context",
              "repository_scan",
              "task_protocol",
              "project_estimate",
              "routing_plan",
              "agent_action",
              "deployment_evidence",
              "workflow_stage"
            ]
          },
          "input_endpoint": { "type": "string", "minLength": 1, "maxLength": 512 },
          "output_endpoint": { "type": "string", "minLength": 1, "maxLength": 512 },
          "output_protocol": {
            "enum": [
              "mergeos.agent-action.v1",
              "mergeos.ai-workflow.v1",
              "mergeos.deployment.v1",
              "mergeos.estimate.v1",
              "mergeos.repo-import.v1",
              "mergeos.routing.v1",
              "mergeos.scan.v1",
              "mergeos.task.v1",
              "mergeos.workflow.v1"
            ]
          },
          "output_protocol_url": { "type": "string", "minLength": 1, "maxLength": 512 },
          "action_endpoint": { "type": "string", "minLength": 1, "maxLength": 512 },
          "context_urls": {
            "type": "object",
            "minProperties": 1,
            "propertyNames": { "type": "string", "minLength": 1, "maxLength": 80 },
            "additionalProperties": { "type": "string", "minLength": 1, "maxLength": 512 }
          },
          "checklist": {
            "type": "array",
            "minItems": 1,
            "maxItems": 8,
            "items": { "type": "string", "minLength": 1, "maxLength": 240 }
          },
          "output_ids": {
            "type": "array",
            "items": { "type": "string", "minLength": 1, "maxLength": 160 }
          },
          "produced_count": { "type": "integer", "minimum": 0 },
          "reference": { "type": "string", "maxLength": 512 },
          "url": { "type": "string", "maxLength": 512 },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      }
    },
    "signals": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "type", "title", "body", "status", "created_at"],
        "properties": {
          "id": { "type": "string", "minLength": 1, "maxLength": 160 },
          "type": { "type": "string", "minLength": 1, "maxLength": 120 },
          "title": { "type": "string", "minLength": 1, "maxLength": 160 },
          "body": { "type": "string", "maxLength": 1000 },
          "status": { "type": "string", "minLength": 1, "maxLength": 80 },
          "reference": { "type": "string", "maxLength": 512 },
          "url": { "type": "string", "maxLength": 512 },
          "delegated_by": { "type": "string", "maxLength": 120 },
          "design_agent": { "type": "string", "maxLength": 120 },
          "subagent_type": { "type": "string", "maxLength": 120 },
          "delegation_chain": {
            "type": "array",
            "maxItems": 8,
            "items": { "type": "string", "minLength": 1, "maxLength": 120 }
          },
          "source_finding_id": { "type": "string", "maxLength": 160 },
          "signal": { "type": "string", "maxLength": 120 },
          "path": { "type": "string", "maxLength": 240 },
          "created_at": { "type": "string", "format": "date-time" }
        }
      }
    }
  }
}
