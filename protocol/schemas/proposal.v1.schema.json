{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mergeos.shop/protocol/proposal.v1.schema.json",
  "title": "MergeOS Proposal v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["protocol_version", "kind", "proposal", "worker_notification", "customer_notification"],
  "properties": {
    "protocol_version": { "const": "mergeos.proposal.v1" },
    "kind": { "const": "proposal" },
    "proposal": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "project_id", "project_title", "task_id", "worker_id", "issue_number", "title", "cover_letter", "bid_cents", "status", "reference", "created_at", "updated_at"],
      "properties": {
        "id": { "type": "string", "minLength": 1, "maxLength": 96 },
        "project_id": { "type": "string", "minLength": 1, "maxLength": 96 },
        "project_title": { "type": "string", "maxLength": 240 },
        "task_id": { "type": "string", "minLength": 1, "maxLength": 96 },
        "claim_id": { "type": "string", "maxLength": 96 },
        "worker_id": { "type": "string", "minLength": 1, "maxLength": 160 },
        "issue_number": { "type": "integer", "minimum": 0 },
        "title": { "type": "string", "minLength": 1, "maxLength": 240 },
        "cover_letter": { "type": "string", "minLength": 1, "maxLength": 2000 },
        "bid_cents": { "type": "integer", "minimum": 1 },
        "estimated_hours": { "type": "number", "minimum": 0 },
        "availability": { "type": "string", "maxLength": 160 },
        "status": { "enum": ["submitted", "reviewing", "accepted", "declined", "withdrawn"] },
        "reference": { "type": "string", "minLength": 1, "maxLength": 512 },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" }
      }
    },
    "worker_notification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "user_id", "project_id", "channel", "subject", "body", "status", "created_at"],
      "properties": {
        "id": { "type": "string", "minLength": 1, "maxLength": 96 },
        "user_id": { "type": "string", "maxLength": 96 },
        "project_id": { "type": "string", "maxLength": 96 },
        "channel": { "const": "proposal" },
        "subject": { "type": "string", "minLength": 1, "maxLength": 240 },
        "body": { "type": "string", "minLength": 1, "maxLength": 2200 },
        "status": { "type": "string", "minLength": 1, "maxLength": 512 },
        "created_at": { "type": "string", "format": "date-time" },
        "read_at": { "type": "string", "format": "date-time" }
      }
    },
    "customer_notification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "user_id", "project_id", "channel", "subject", "body", "status", "created_at"],
      "properties": {
        "id": { "type": "string", "minLength": 1, "maxLength": 96 },
        "user_id": { "type": "string", "maxLength": 96 },
        "project_id": { "type": "string", "maxLength": 96 },
        "channel": { "const": "proposal" },
        "subject": { "type": "string", "minLength": 1, "maxLength": 240 },
        "body": { "type": "string", "minLength": 1, "maxLength": 2200 },
        "status": { "type": "string", "minLength": 1, "maxLength": 512 },
        "created_at": { "type": "string", "format": "date-time" },
        "read_at": { "type": "string", "format": "date-time" }
      }
    }
  }
}
