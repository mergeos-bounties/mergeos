{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mergeos.shop/protocol/live-feed.v1.schema.json",
  "title": "MergeOS Live Feed v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["protocol_version", "kind", "stats", "items"],
  "$defs": {
    "contextUrls": {
      "type": "array",
      "maxItems": 8,
      "items": { "type": "string", "minLength": 1, "maxLength": 512 }
    },
    "packetText": {
      "type": "array",
      "maxItems": 12,
      "items": { "type": "string", "minLength": 1, "maxLength": 220 }
    },
    "checks": {
      "type": "array",
      "maxItems": 12,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "status"],
        "properties": {
          "name": { "type": "string", "minLength": 1, "maxLength": 120 },
          "status": { "enum": ["passed", "failed", "warning", "running", "skipped"] },
          "summary": { "type": "string", "maxLength": 260 },
          "reference_url": { "type": "string", "maxLength": 512 }
        }
      }
    }
  },
  "properties": {
    "protocol_version": { "const": "mergeos.live-feed.v1" },
    "kind": { "const": "live_feed" },
    "stats": {
      "type": "object",
      "additionalProperties": false,
      "required": ["project_count", "open_task_count", "accepted_task_count", "active_contributor_count", "active_agent_count", "ledger_entry_count", "ai_action_count", "total_budget_cents", "token_symbol"],
      "properties": {
        "project_count": { "type": "integer", "minimum": 0 },
        "open_task_count": { "type": "integer", "minimum": 0 },
        "accepted_task_count": { "type": "integer", "minimum": 0 },
        "proposal_count": { "type": "integer", "minimum": 0 },
        "active_contributor_count": { "type": "integer", "minimum": 0 },
        "active_agent_count": { "type": "integer", "minimum": 0 },
        "ledger_entry_count": { "type": "integer", "minimum": 0 },
        "ai_action_count": { "type": "integer", "minimum": 0 },
        "total_budget_cents": { "type": "integer", "minimum": 0 },
        "token_symbol": { "type": "string", "minLength": 1, "maxLength": 16 },
        "updated_at": { "type": "string", "format": "date-time" }
      }
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "type", "title", "body", "status", "created_at"],
        "properties": {
          "id": { "type": "string", "minLength": 1, "maxLength": 200 },
          "type": {
            "enum": [
              "project_funded",
              "deployment_validation",
              "task_opened",
              "task_claimed",
              "task_submitted",
              "task_changes_requested",
              "task_accepted",
              "ledger_payment_verified",
              "ledger_token_mint",
              "ledger_platform_fee",
              "ledger_project_reserve",
              "ledger_task_reserve",
              "ledger_task_payment",
              "ledger_manual_credit",
              "proposal_submitted",
              "proposal_accepted",
              "proposal_declined",
              "repo_issues_synced",
              "agent_action",
              "pr_opened",
              "ai_review"
            ]
          },
          "title": { "type": "string", "minLength": 1, "maxLength": 240 },
          "body": { "type": "string", "maxLength": 2000 },
          "project_id": { "type": "string", "maxLength": 96 },
          "project_title": { "type": "string", "maxLength": 240 },
          "task_id": { "type": "string", "maxLength": 96 },
          "actor": { "type": "string", "maxLength": 160 },
          "action": { "type": "string", "maxLength": 80 },
          "amount_cents": { "type": "integer", "minimum": 0 },
          "ledger_sequence": { "type": "integer", "minimum": 1 },
          "entry_hash": { "type": "string", "minLength": 64, "maxLength": 64 },
          "reference": { "type": "string", "maxLength": 512 },
          "evidence_required": {
            "type": "array",
            "items": { "type": "string", "minLength": 1, "maxLength": 120 }
          },
          "context_urls": { "$ref": "#/$defs/contextUrls" },
          "evidence": { "$ref": "#/$defs/packetText" },
          "runbook": { "$ref": "#/$defs/packetText" },
          "checks": { "$ref": "#/$defs/checks" },
          "delegated_by": { "type": "string", "maxLength": 120 },
          "design_agent": { "type": "string", "maxLength": 120 },
          "subagent_type": { "type": "string", "maxLength": 120 },
          "delegation_chain": {
            "type": "array",
            "maxItems": 8,
            "items": { "type": "string", "minLength": 1, "maxLength": 120 }
          },
          "url": { "type": "string", "maxLength": 512 },
          "status": { "type": "string", "minLength": 1, "maxLength": 160 },
          "created_at": { "type": "string", "format": "date-time" }
        }
      }
    },
    "cursor": { "type": "string", "minLength": 1, "maxLength": 200 },
    "after_id": { "type": "string", "minLength": 1, "maxLength": 200 },
    "since": { "type": "string", "format": "date-time" },
    "replay": { "type": "boolean" },
    "cursor_found": { "type": "boolean" },
    "has_more": { "type": "boolean" },
    "total_item_count": { "type": "integer", "minimum": 0 }
  }
}
