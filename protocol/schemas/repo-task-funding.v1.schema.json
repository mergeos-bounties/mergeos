{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mergeos.shop/protocol/repo-task-funding.v1.schema.json",
  "title": "MergeOS Repository Task Funding v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["protocol_version", "kind", "project_id", "suggested_task_id", "task", "ledger_entries", "work_packet"],
  "properties": {
    "protocol_version": { "const": "mergeos.repo-task-funding.v1" },
    "kind": { "const": "repo_task_funding" },
    "project_id": { "type": "string", "minLength": 3, "maxLength": 96 },
    "suggested_task_id": { "type": "string", "minLength": 1, "maxLength": 160 },
    "funding_reference": { "type": "string", "maxLength": 512 },
    "evidence_checklist": {
      "type": "array",
      "items": { "type": "string", "minLength": 1, "maxLength": 120 }
    },
    "task_protocol_url": { "type": "string", "maxLength": 512 },
    "workflow_protocol_url": { "type": "string", "maxLength": 512 },
    "scan_protocol_url": { "type": "string", "maxLength": 512 },
    "task": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "project_id", "title", "reward_cents", "status"],
      "properties": {
        "id": { "type": "string", "minLength": 3, "maxLength": 96 },
        "project_id": { "type": "string", "minLength": 3, "maxLength": 96 },
        "issue_number": { "type": "integer", "minimum": 0 },
        "title": { "type": "string", "minLength": 1, "maxLength": 500 },
        "acceptance": { "type": "string", "maxLength": 5000 },
        "reward_cents": { "type": "integer", "minimum": 0 },
        "required_worker_kind": { "enum": ["human", "agent", "hybrid"] },
        "suggested_agent_type": { "type": "string", "maxLength": 120 },
        "bounty_type": { "type": "string", "maxLength": 120 },
        "status": { "type": "string", "minLength": 1, "maxLength": 80 },
        "issue_url": { "type": "string", "maxLength": 512 },
        "created_at": { "type": "string", "format": "date-time" }
      }
    },
    "ledger_entries": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["sequence", "type", "amount_cents", "reference", "entry_hash"],
        "properties": {
          "sequence": { "type": "integer", "minimum": 1 },
          "type": { "type": "string", "minLength": 1, "maxLength": 120 },
          "from_account": { "type": "string", "maxLength": 200 },
          "to_account": { "type": "string", "maxLength": 200 },
          "amount_cents": { "type": "integer", "minimum": 0 },
          "reference": { "type": "string", "maxLength": 512 },
          "entry_hash": { "type": "string", "minLength": 64, "maxLength": 64 },
          "created_at": { "type": "string", "format": "date-time" }
        }
      }
    },
    "work_packet": {
      "type": "object",
      "additionalProperties": false,
      "required": ["claim_endpoint", "action_endpoint", "submit_endpoint", "context_urls", "runbook", "action_payloads"],
      "properties": {
        "claim_endpoint": { "type": "string", "minLength": 1, "maxLength": 512 },
        "action_endpoint": { "type": "string", "minLength": 1, "maxLength": 512 },
        "submit_endpoint": { "type": "string", "minLength": 1, "maxLength": 512 },
        "supervisor_agent_type": { "type": "string", "maxLength": 120 },
        "subagent_type": { "type": "string", "maxLength": 120 },
        "design_review_agent": { "type": "string", "maxLength": 120 },
        "delegation_chain": {
          "type": "array",
          "items": { "type": "string", "minLength": 1, "maxLength": 120 }
        },
        "context_urls": {
          "type": "object",
          "additionalProperties": { "type": "string", "minLength": 1, "maxLength": 512 }
        },
        "runbook": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["step", "action", "label", "method", "endpoint"],
            "properties": {
              "step": { "type": "integer", "minimum": 1 },
              "action": { "type": "string", "minLength": 1, "maxLength": 120 },
              "label": { "type": "string", "minLength": 1, "maxLength": 240 },
              "method": { "enum": ["GET", "POST", "PATCH", "DELETE"] },
              "endpoint": { "type": "string", "minLength": 1, "maxLength": 512 }
            }
          }
        },
        "action_payloads": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["action", "label", "method", "endpoint", "body"],
            "properties": {
              "action": { "type": "string", "minLength": 1, "maxLength": 120 },
              "label": { "type": "string", "minLength": 1, "maxLength": 240 },
              "method": { "enum": ["POST"] },
              "endpoint": { "type": "string", "minLength": 1, "maxLength": 512 },
              "body": { "type": "object" }
            }
          }
        }
      }
    }
  }
}
