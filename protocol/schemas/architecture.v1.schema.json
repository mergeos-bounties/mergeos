{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mergeos.shop/protocol/architecture.v1.schema.json",
  "title": "MergeOS Product Architecture",
  "type": "object",
  "required": [
    "protocol_version",
    "kind",
    "product",
    "positioning",
    "thesis",
    "product_vision",
    "repository_architecture",
    "users",
    "frontend_system",
    "backend_system",
    "ai_layer",
    "marketplace_system",
    "live_feed_system",
    "ledger_system",
    "token_economy_system",
    "public_urls"
  ],
  "properties": {
    "protocol_version": { "const": "mergeos.architecture.v1" },
    "kind": { "const": "product_architecture" },
    "product": { "const": "MergeOS" },
    "positioning": { "type": "string", "minLength": 1 },
    "thesis": { "type": "string", "minLength": 1 },
    "not_a": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "product_vision": {
      "type": "object",
      "required": ["summary", "core_loop", "workflow_routes"],
      "properties": {
        "summary": { "type": "string", "minLength": 1 },
        "core_loop": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "workflow_routes": {
          "type": "object",
          "required": [
            "import_repository",
            "scan_issues_with_ai",
            "generate_task_graph",
            "estimate_rewards",
            "fund_escrow",
            "route_contributors_or_agents",
            "review_pull_requests",
            "validate_deployment",
            "release_payment",
            "publish_ledger_proof"
          ],
          "properties": {
            "import_repository": { "$ref": "#/$defs/workflowRoute" },
            "scan_issues_with_ai": { "$ref": "#/$defs/workflowRoute" },
            "generate_task_graph": { "$ref": "#/$defs/workflowRoute" },
            "estimate_rewards": { "$ref": "#/$defs/workflowRoute" },
            "fund_escrow": { "$ref": "#/$defs/workflowRoute" },
            "route_contributors_or_agents": { "$ref": "#/$defs/workflowRoute" },
            "review_pull_requests": { "$ref": "#/$defs/workflowRoute" },
            "validate_deployment": { "$ref": "#/$defs/workflowRoute" },
            "release_payment": { "$ref": "#/$defs/workflowRoute" },
            "publish_ledger_proof": { "$ref": "#/$defs/workflowRoute" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "repository_architecture": {
      "type": "array",
      "minItems": 4,
      "items": {
        "type": "object",
        "required": ["name", "role", "contains", "artifact_urls"],
        "properties": {
          "name": { "enum": ["mergeos-app", "mergeos-contracts", "mergeos-sdk", "mergeos-protocol"] },
          "role": { "type": "string", "minLength": 1 },
          "contains": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "artifact_urls": {
            "type": "object",
            "required": ["primary", "protocol", "public_reference"],
            "properties": {
              "primary": { "type": "string", "minLength": 1 },
              "protocol": { "type": "string", "minLength": 1 },
              "public_reference": { "type": "string", "minLength": 1 }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    },
    "users": {
      "type": "array",
      "minItems": 4,
      "items": {
        "type": "object",
        "required": ["type", "examples", "role_routes"],
        "properties": {
          "type": { "enum": ["customers", "contributors", "ai_agents", "admins"] },
          "examples": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "dashboard": { "type": "string" },
          "surface": { "type": "string" },
          "role_routes": { "$ref": "#/$defs/roleRoute" }
        },
        "additionalProperties": false
      }
    },
    "frontend_system": {
      "type": "object",
      "required": ["stack", "public_pages", "public_page_routes", "authenticated_dashboards", "authenticated_dashboard_urls"],
      "properties": {
        "stack": { "$ref": "#/$defs/stringList" },
        "public_pages": { "$ref": "#/$defs/stringList" },
        "public_page_routes": {
          "type": "object",
          "required": ["homepage", "marketplace", "live_feed", "ledger_logs", "protocol", "mergeide", "airdrop", "presale", "whitepaper"],
          "properties": {
            "homepage": { "$ref": "#/$defs/publicPageRoute" },
            "marketplace": { "$ref": "#/$defs/publicPageRoute" },
            "live_feed": { "$ref": "#/$defs/publicPageRoute" },
            "ledger_logs": { "$ref": "#/$defs/publicPageRoute" },
            "protocol": { "$ref": "#/$defs/publicPageRoute" },
            "mergeide": { "$ref": "#/$defs/publicPageRoute" },
            "airdrop": { "$ref": "#/$defs/publicPageRoute" },
            "presale": { "$ref": "#/$defs/publicPageRoute" },
            "whitepaper": { "$ref": "#/$defs/publicPageRoute" }
          },
          "additionalProperties": false
        },
        "authenticated_dashboards": { "$ref": "#/$defs/stringList" },
        "authenticated_dashboard_urls": {
          "type": "object",
          "required": ["customer_dashboard", "worker_dashboard", "admin_console"],
          "properties": {
            "customer_dashboard": {
              "type": "object",
              "required": ["page", "api", "capabilities"],
              "properties": {
                "page": { "type": "string", "minLength": 1 },
                "api": { "type": "string", "minLength": 1 },
                "capabilities": { "$ref": "#/$defs/stringList" }
              },
              "additionalProperties": false
            },
            "worker_dashboard": {
              "type": "object",
              "required": ["page", "api", "capabilities"],
              "properties": {
                "page": { "type": "string", "minLength": 1 },
                "api": { "type": "string", "minLength": 1 },
                "capabilities": { "$ref": "#/$defs/stringList" }
              },
              "additionalProperties": false
            },
            "admin_console": {
              "type": "object",
              "required": ["page", "api", "capabilities"],
              "properties": {
                "page": { "type": "string", "minLength": 1 },
                "api": { "type": "string", "minLength": 1 },
                "capabilities": { "$ref": "#/$defs/stringList" }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "backend_system": {
      "type": "object",
      "required": ["role", "proposed_stack", "runtime_routes", "service_boundaries"],
      "properties": {
        "role": { "type": "string", "minLength": 1 },
        "proposed_stack": { "$ref": "#/$defs/stringList" },
        "runtime_routes": {
          "type": "object",
          "required": ["authentication", "repository_import", "ai_orchestration", "task_engine", "payment_verification", "escrow_coordination", "live_notifications", "ledger_system"],
          "properties": {
            "authentication": { "type": "string", "minLength": 1 },
            "repository_import": { "type": "string", "minLength": 1 },
            "ai_orchestration": { "type": "string", "minLength": 1 },
            "task_engine": { "type": "string", "minLength": 1 },
            "payment_verification": { "type": "string", "minLength": 1 },
            "escrow_coordination": { "type": "string", "minLength": 1 },
            "live_notifications": { "type": "string", "minLength": 1 },
            "ledger_system": { "type": "string", "minLength": 1 }
          },
          "additionalProperties": false
        },
        "service_boundaries": {
          "type": "object",
          "required": ["authentication", "repositories", "ai_orchestration", "task_engine", "payment_verification", "escrow_coordination", "live_notifications", "ledger_system"],
          "properties": {
            "authentication": { "$ref": "#/$defs/backendServiceBoundary" },
            "repositories": { "$ref": "#/$defs/backendServiceBoundary" },
            "ai_orchestration": { "$ref": "#/$defs/backendServiceBoundary" },
            "task_engine": { "$ref": "#/$defs/backendServiceBoundary" },
            "payment_verification": { "$ref": "#/$defs/backendServiceBoundary" },
            "escrow_coordination": { "$ref": "#/$defs/backendServiceBoundary" },
            "live_notifications": { "$ref": "#/$defs/backendServiceBoundary" },
            "ledger_system": { "$ref": "#/$defs/backendServiceBoundary" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "ai_layer": {
      "type": "object",
      "required": ["capabilities", "workflow", "action_routes"],
      "properties": {
        "capabilities": { "$ref": "#/$defs/stringList" },
        "workflow": { "$ref": "#/$defs/stringList" },
        "action_routes": {
          "type": "object",
          "required": ["scan_repository", "analyze_issues", "generate_tasks", "route_workers", "review_prs", "test_builds", "validate_deployments"],
          "properties": {
            "scan_repository": { "$ref": "#/$defs/aiActionRoute" },
            "analyze_issues": { "$ref": "#/$defs/aiActionRoute" },
            "generate_tasks": { "$ref": "#/$defs/aiActionRoute" },
            "route_workers": { "$ref": "#/$defs/aiActionRoute" },
            "review_prs": { "$ref": "#/$defs/aiActionRoute" },
            "test_builds": { "$ref": "#/$defs/aiActionRoute" },
            "validate_deployments": { "$ref": "#/$defs/aiActionRoute" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "marketplace_system": {
      "type": "object",
      "required": ["role", "features", "feature_routes", "action_routes"],
      "properties": {
        "role": { "type": "string", "minLength": 1 },
        "features": { "$ref": "#/$defs/stringList" },
        "feature_routes": {
          "type": "object",
          "required": ["live_projects", "public_bounties", "contributors", "ai_agents"],
          "properties": {
            "live_projects": { "$ref": "#/$defs/marketplaceFeatureRoute" },
            "public_bounties": { "$ref": "#/$defs/marketplaceFeatureRoute" },
            "contributors": { "$ref": "#/$defs/marketplaceFeatureRoute" },
            "ai_agents": { "$ref": "#/$defs/marketplaceFeatureRoute" }
          },
          "additionalProperties": false
        },
        "action_routes": {
          "type": "object",
          "required": ["publish_bounty", "submit_proposal", "claim_task", "lease_agent_work", "submit_evidence"],
          "properties": {
            "publish_bounty": { "$ref": "#/$defs/marketplaceActionRoute" },
            "submit_proposal": { "$ref": "#/$defs/marketplaceActionRoute" },
            "claim_task": { "$ref": "#/$defs/marketplaceActionRoute" },
            "lease_agent_work": { "$ref": "#/$defs/marketplaceActionRoute" },
            "submit_evidence": { "$ref": "#/$defs/marketplaceActionRoute" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "live_feed_system": {
      "type": "object",
      "required": ["role", "features", "event_routes"],
      "properties": {
        "role": { "type": "string", "minLength": 1 },
        "features": { "$ref": "#/$defs/stringList" },
        "event_routes": {
          "type": "object",
          "required": ["live_prs", "deployments", "contributors", "ai_actions"],
          "properties": {
            "live_prs": { "$ref": "#/$defs/liveFeedEventRoute" },
            "deployments": { "$ref": "#/$defs/liveFeedEventRoute" },
            "contributors": { "$ref": "#/$defs/liveFeedEventRoute" },
            "ai_actions": { "$ref": "#/$defs/liveFeedEventRoute" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "ledger_system": {
      "type": "object",
      "required": ["role", "features", "proof_routes"],
      "properties": {
        "role": { "type": "string", "minLength": 1 },
        "features": { "$ref": "#/$defs/stringList" },
        "proof_routes": {
          "type": "object",
          "required": ["payouts", "escrow_events", "pr_events", "ai_actions", "releases"],
          "properties": {
            "payouts": { "$ref": "#/$defs/ledgerProofRoute" },
            "escrow_events": { "$ref": "#/$defs/ledgerProofRoute" },
            "pr_events": { "$ref": "#/$defs/ledgerProofRoute" },
            "ai_actions": { "$ref": "#/$defs/ledgerProofRoute" },
            "releases": { "$ref": "#/$defs/ledgerProofRoute" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "token_economy_system": {
      "type": "object",
      "required": ["role", "features", "protocol_routes"],
      "properties": {
        "role": { "type": "string", "minLength": 1 },
        "features": { "$ref": "#/$defs/stringList" },
        "protocol_routes": {
          "type": "object",
          "required": ["public_supply", "airdrop_claims", "presale_reservations", "wallet_migration", "payout_settlement", "solana_contract"],
          "properties": {
            "public_supply": { "$ref": "#/$defs/tokenEconomyRoute" },
            "airdrop_claims": { "$ref": "#/$defs/tokenEconomyRoute" },
            "presale_reservations": { "$ref": "#/$defs/tokenEconomyRoute" },
            "wallet_migration": { "$ref": "#/$defs/tokenEconomyRoute" },
            "payout_settlement": { "$ref": "#/$defs/tokenEconomyRoute" },
            "solana_contract": { "$ref": "#/$defs/tokenEconomyRoute" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "public_urls": {
      "type": "object",
      "required": [
        "system",
        "marketplace",
        "live_feed",
        "ledger",
        "protocol",
        "whitepaper",
        "architecture_manifest",
        "marketplace_api",
        "live_feed_api",
        "agent_queue_api",
        "ledger_api",
        "ledger_events_api",
        "ledger_verify_api",
        "ledger_proof_api",
        "token_economy_api",
        "airdrop_missions_api",
        "airdrop_claims_api",
        "presale_reservations_api",
        "project_escrow_api",
        "project_payouts_api",
        "solana_mrg_idl",
        "solana_mrg_proof_manifest"
      ],
      "properties": {
        "system": { "type": "string", "minLength": 1 },
        "marketplace": { "type": "string", "minLength": 1 },
        "live_feed": { "type": "string", "minLength": 1 },
        "ledger": { "type": "string", "minLength": 1 },
        "protocol": { "type": "string", "minLength": 1 },
        "whitepaper": { "type": "string", "minLength": 1 },
        "architecture_manifest": { "type": "string", "minLength": 1 },
        "marketplace_api": { "type": "string", "minLength": 1 },
        "live_feed_api": { "type": "string", "minLength": 1 },
        "agent_queue_api": { "type": "string", "minLength": 1 },
        "ledger_api": { "type": "string", "minLength": 1 },
        "ledger_events_api": { "type": "string", "minLength": 1 },
        "ledger_verify_api": { "type": "string", "minLength": 1 },
        "ledger_proof_api": { "type": "string", "minLength": 1 },
        "token_economy_api": { "type": "string", "minLength": 1 },
        "airdrop_missions_api": { "type": "string", "minLength": 1 },
        "airdrop_claims_api": { "type": "string", "minLength": 1 },
        "presale_reservations_api": { "type": "string", "minLength": 1 },
        "project_escrow_api": { "type": "string", "minLength": 1 },
        "project_payouts_api": { "type": "string", "minLength": 1 },
        "solana_mrg_idl": { "type": "string", "minLength": 1 },
        "solana_mrg_proof_manifest": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "backendServiceBoundary": {
      "type": "object",
      "required": ["owner", "primary_api", "state_store", "external_dependencies", "output_protocols"],
      "properties": {
        "owner": { "type": "string", "minLength": 1 },
        "primary_api": { "type": "string", "minLength": 1 },
        "state_store": { "type": "string", "minLength": 1 },
        "external_dependencies": { "$ref": "#/$defs/stringList" },
        "output_protocols": { "$ref": "#/$defs/stringList" }
      },
      "additionalProperties": false
    },
    "publicPageRoute": {
      "type": "object",
      "required": ["page", "api", "seo_title", "proof_surface"],
      "properties": {
        "page": { "type": "string", "minLength": 1 },
        "api": { "type": "string", "minLength": 1 },
        "seo_title": { "type": "string", "minLength": 1 },
        "proof_surface": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "roleRoute": {
      "type": "object",
      "required": ["page", "api", "capabilities"],
      "properties": {
        "page": { "type": "string", "minLength": 1 },
        "api": { "type": "string", "minLength": 1 },
        "capabilities": { "$ref": "#/$defs/stringList" }
      },
      "additionalProperties": false
    },
    "workflowRoute": {
      "type": "object",
      "required": ["page", "api", "proof_surface"],
      "properties": {
        "page": { "type": "string", "minLength": 1 },
        "api": { "type": "string", "minLength": 1 },
        "proof_surface": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "marketplaceFeatureRoute": {
      "type": "object",
      "required": ["page", "api", "event_type"],
      "properties": {
        "page": { "type": "string", "minLength": 1 },
        "api": { "type": "string", "minLength": 1 },
        "event_type": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "marketplaceActionRoute": {
      "type": "object",
      "required": ["command", "api", "output_protocol", "proof_surface"],
      "properties": {
        "command": { "type": "string", "minLength": 1 },
        "api": { "type": "string", "minLength": 1 },
        "output_protocol": { "type": "string", "minLength": 1 },
        "proof_surface": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "liveFeedEventRoute": {
      "type": "object",
      "required": ["page", "api", "event_type", "ledger_tab"],
      "properties": {
        "page": { "type": "string", "minLength": 1 },
        "api": { "type": "string", "minLength": 1 },
        "event_type": { "type": "string", "minLength": 1 },
        "ledger_tab": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "ledgerProofRoute": {
      "type": "object",
      "required": ["page", "api", "event_type", "proof_api"],
      "properties": {
        "page": { "type": "string", "minLength": 1 },
        "api": { "type": "string", "minLength": 1 },
        "event_type": { "type": "string", "minLength": 1 },
        "proof_api": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "tokenEconomyRoute": {
      "type": "object",
      "required": ["page", "api", "output_protocol", "proof_surface"],
      "properties": {
        "page": { "type": "string", "minLength": 1 },
        "api": { "type": "string", "minLength": 1 },
        "output_protocol": { "type": "string", "minLength": 1 },
        "proof_surface": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "aiActionRoute": {
      "type": "object",
      "required": ["api", "output_protocol", "proof_surface"],
      "properties": {
        "api": { "type": "string", "minLength": 1 },
        "output_protocol": { "type": "string", "minLength": 1 },
        "proof_surface": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "stringList": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "additionalProperties": false
}
