{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mergeos.shop/protocol/task.v1.schema.json",
  "title": "MergeOS Task v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["protocol_version", "kind", "id", "title", "reward_mrg", "worker_kind", "acceptance_criteria"],
  "properties": {
    "protocol_version": { "const": "mergeos.task.v1" },
    "kind": { "const": "task" },
    "id": { "type": "string", "minLength": 3, "maxLength": 96 },
    "project_id": { "type": "string", "maxLength": 96 },
    "title": { "type": "string", "minLength": 3, "maxLength": 240 },
    "summary": { "type": "string", "maxLength": 2000 },
    "source_repository": { "type": "string", "maxLength": 512 },
    "issue_url": { "type": "string", "maxLength": 512 },
    "reward_mrg": { "type": "number", "minimum": 0 },
    "estimated_hours": { "type": "number", "minimum": 0 },
    "bounty_type": { "type": "string", "maxLength": 80 },
    "worker_kind": { "enum": ["human", "agent", "hybrid"] },
    "agent_type": { "type": "string", "maxLength": 120 },
    "acceptance_criteria": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1, "maxLength": 500 }
    },
    "dependencies": {
      "type": "array",
      "items": { "type": "string", "minLength": 1, "maxLength": 96 }
    },
    "evidence_required": {
      "type": "array",
      "items": {
        "enum": ["screenshot", "video", "logs", "tests", "deploy_preview", "transaction_proof", "security_review"]
      }
    },
    "tags": {
      "type": "array",
      "items": { "type": "string", "minLength": 1, "maxLength": 80 }
    },
    "metadata": { "type": "object" }
  }
}
