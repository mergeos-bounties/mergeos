MERGEOS_ENV=local
PORT=8080
MERGEOS_STATE_PATH=data/mergeos-state.local.json
TOKEN_SYMBOL=MERGE
PLATFORM_FEE_BPS=1000

# Local-only convenience. Use LOCAL-PAID while developing.
DEV_PAYMENT_ENABLED=true
DEV_PAYMENT_CODE=LOCAL-PAID

# Local admin bootstrap. Change before sharing a machine.
ADMIN_AUTO_PROMOTE_FIRST_USER=true
ADMIN_EMAIL=admin@mergeos.local
ADMIN_PASSWORD=mergeosadmin123
ADMIN_NAME=MergeOS Admin
ADMIN_COMPANY_NAME=MergeOS

# Local adapters stay empty unless you are testing real integrations.
PAYPAL_ENV=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
CRYPTO_RPC_URL=
CRYPTO_RECEIVER=
CRYPTO_ASSET=erc20
CRYPTO_TOKEN_CONTRACT=
CRYPTO_TOKEN_DECIMALS=6
CRYPTO_WEI_PER_USD_CENT=
CRYPTO_MIN_CONFIRMATIONS=1

GITHUB_TOKEN=
GITHUB_OWNER=mergeos-bounties
GITHUB_OWNER_TYPE=org
BOUNTY_ROOT=../bounties/local
UPLOAD_ROOT=data/uploads/local

SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@mergeos.local
