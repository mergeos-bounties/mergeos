MERGEOS_ENV=production
PORT=8080
# Production PostgreSQL connection. The GitHub deploy workflow provisions this
# automatically on the VPS and injects DATABASE_URL into the systemd service.
DATABASE_URL=postgres://mergeos:change-me@127.0.0.1:5432/mergeos?sslmode=disable
# Legacy JSON state import path. If Postgres is empty, this file is imported once.
MERGEOS_STATE_PATH=data/mergeos-state.production.json
TOKEN_SYMBOL=MRG
PLATFORM_FEE_BPS=1000
PRIMARY_DOMAIN=mergeos.shop
ADMIN_DOMAIN=uta.mergeos.shop
SCAN_DOMAIN=scan.mergeos.shop

# Production must use real payment adapters.
DEV_PAYMENT_ENABLED=false
DEV_PAYMENT_CODE=

# Production admin should be explicit, never first-user bootstrap.
ADMIN_AUTO_PROMOTE_FIRST_USER=false
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-before-deploying
ADMIN_NAME=MergeOS Admin
ADMIN_COMPANY_NAME=MergeOS

# Live adapters.
PAYPAL_ENV=live
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=

CRYPTO_RPC_URL=
CRYPTO_RECEIVER=
CRYPTO_ASSET=spl
CRYPTO_TOKEN_MINT=
CRYPTO_TOKEN_DECIMALS=6
CRYPTO_MIN_CONFIRMATIONS=3
MRG_SOLANA_PROGRAM_ID=
CRYPTO_WEBHOOK_SECRET=

GITHUB_TOKEN=
GITHUB_OWNER=mergeos-bounties
GITHUB_OWNER_TYPE=org
GEMINI_API_KEYS=
GEMINI_REVIEW_MODEL=gemini-2.5-flash
OPENAI_API_KEYS=
OPENAI_REVIEW_MODEL=gpt-4.1-mini
ANTHROPIC_API_KEYS=
ANTHROPIC_REVIEW_MODEL=claude-3-5-sonnet-latest
GROQ_API_KEYS=
GROQ_REVIEW_MODEL=llama-3.3-70b-versatile
OPENROUTER_API_KEYS=
OPENROUTER_REVIEW_MODEL=openai/gpt-4o-mini
DEEPSEEK_API_KEYS=
DEEPSEEK_REVIEW_MODEL=deepseek-chat
MISTRAL_API_KEYS=
MISTRAL_REVIEW_MODEL=mistral-large-latest
GEMINI_REVIEW_WEBHOOK_SECRET=
GEMINI_REVIEW_MAX_PATCH_BYTES=70000
GITHUB_APP_ID=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
BOUNTY_ROOT=../bounties/production
UPLOAD_ROOT=data/uploads/production

SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com
