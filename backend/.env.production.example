MERGEOS_ENV=production
PORT=8080
MERGEOS_STATE_PATH=data/mergeos-state.production.json
TOKEN_SYMBOL=MERGE
PLATFORM_FEE_BPS=1000

# Production must use real payment adapters.
DEV_PAYMENT_ENABLED=false
DEV_PAYMENT_CODE=

# Production admin should be explicit, never first-user bootstrap.
ADMIN_AUTO_PROMOTE_FIRST_USER=false
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-before-deploying
ADMIN_NAME=MergeOS Admin
ADMIN_COMPANY_NAME=MergeOS

# Live adapters.
PAYPAL_ENV=live
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

CRYPTO_RPC_URL=
CRYPTO_RECEIVER=
CRYPTO_ASSET=erc20
CRYPTO_TOKEN_CONTRACT=
CRYPTO_TOKEN_DECIMALS=6
CRYPTO_WEI_PER_USD_CENT=
CRYPTO_MIN_CONFIRMATIONS=3

GITHUB_TOKEN=
GITHUB_OWNER=mergeos-bounties
GITHUB_OWNER_TYPE=org
BOUNTY_ROOT=../bounties/production
UPLOAD_ROOT=data/uploads/production

SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com
