{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mergeos.shop/protocol/repo-sync.v1.schema.json",
  "title": "MergeOS Repository Sync v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["protocol_version", "kind", "project_id", "project_title", "source_repo_url", "imported_issue_count", "added_task_count", "updated_task_count", "open_issue_count", "closed_issue_count", "planning_packet", "issue_mappings", "synced_at"],
  "properties": {
    "protocol_version": { "const": "mergeos.repo-sync.v1" },
    "kind": { "const": "repo_sync" },
    "project_id": { "type": "string", "minLength": 1, "maxLength": 96 },
    "project_title": { "type": "string", "maxLength": 240 },
    "source_repo_url": { "type": "string", "maxLength": 512 },
    "imported_issue_count": { "type": "integer", "minimum": 0 },
    "added_task_count": { "type": "integer", "minimum": 0 },
    "updated_task_count": { "type": "integer", "minimum": 0 },
    "open_issue_count": { "type": "integer", "minimum": 0 },
    "closed_issue_count": { "type": "integer", "minimum": 0 },
    "planning_packet": { "$ref": "#/$defs/planningPacket" },
    "issue_mappings": {
      "type": "array",
      "items": { "$ref": "#/$defs/issueMapping" }
    },
    "synced_at": { "type": "string", "format": "date-time" }
  },
  "$defs": {
    "planningPacket": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "supervisor_agent_type", "context_urls", "runbook", "steps", "output_contracts", "summary"],
      "properties": {
        "status": { "type": "string", "minLength": 1, "maxLength": 120 },
        "supervisor_agent_type": { "type": "string", "minLength": 1, "maxLength": 120 },
        "context_urls": {
          "type": "object",
          "additionalProperties": { "type": "string", "minLength": 1, "maxLength": 512 }
        },
        "runbook": { "type": "array", "items": { "$ref": "#/$defs/runbookStep" } },
        "steps": { "type": "array", "items": { "$ref": "#/$defs/planningStep" } },
        "output_contracts": { "type": "array", "items": { "$ref": "#/$defs/outputContract" } },
        "summary": { "$ref": "#/$defs/planningSummary" }
      }
    },
    "runbookStep": {
      "type": "object",
      "additionalProperties": false,
      "required": ["step", "action", "label", "method", "endpoint"],
      "properties": {
        "step": { "type": "integer", "minimum": 1 },
        "action": { "type": "string", "minLength": 1, "maxLength": 120 },
        "label": { "type": "string", "minLength": 1, "maxLength": 240 },
        "method": { "enum": ["GET", "POST", "PATCH", "DELETE"] },
        "endpoint": { "type": "string", "minLength": 1, "maxLength": 240 }
      }
    },
    "planningStep": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "status", "artifact_kind", "output_endpoint", "output_protocol", "output_protocol_url"],
      "properties": {
        "id": { "type": "string", "minLength": 1, "maxLength": 120 },
        "title": { "type": "string", "minLength": 1, "maxLength": 160 },
        "status": { "type": "string", "minLength": 1, "maxLength": 80 },
        "artifact_kind": { "type": "string", "minLength": 1, "maxLength": 120 },
        "output_endpoint": { "type": "string", "minLength": 1, "maxLength": 240 },
        "output_protocol": { "type": "string", "minLength": 1, "maxLength": 120 },
        "output_protocol_url": { "type": "string", "minLength": 1, "maxLength": 512 }
      }
    },
    "outputContract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action", "artifact_kind", "output_endpoint", "output_protocol", "output_protocol_url"],
      "properties": {
        "action": { "type": "string", "minLength": 1, "maxLength": 120 },
        "artifact_kind": { "type": "string", "minLength": 1, "maxLength": 120 },
        "output_endpoint": { "type": "string", "minLength": 1, "maxLength": 240 },
        "output_protocol": { "type": "string", "minLength": 1, "maxLength": 120 },
        "output_protocol_url": { "type": "string", "minLength": 1, "maxLength": 512 },
        "public_url": { "type": "string", "minLength": 1, "maxLength": 512 }
      }
    },
    "planningSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["issue_count", "task_count", "agent_task_count", "human_task_count", "hybrid_task_count", "total_reward_cents", "total_estimated_hours"],
      "properties": {
        "issue_count": { "type": "integer", "minimum": 0 },
        "task_count": { "type": "integer", "minimum": 0 },
        "agent_task_count": { "type": "integer", "minimum": 0 },
        "human_task_count": { "type": "integer", "minimum": 0 },
        "hybrid_task_count": { "type": "integer", "minimum": 0 },
        "total_reward_cents": { "type": "integer", "minimum": 0 },
        "total_estimated_hours": { "type": "number", "minimum": 0 }
      }
    },
    "issueMapping": {
      "type": "object",
      "additionalProperties": false,
      "required": ["issue_number", "issue_title", "issue_state", "sync_status", "task_id", "task_title", "task_status", "claim_id", "claim_endpoint", "task_protocol_url", "action_endpoint", "reward_cents", "reward_mrg", "estimated_hours", "required_worker_kind", "routing"],
      "properties": {
        "issue_number": { "type": "integer", "minimum": 1 },
        "issue_title": { "type": "string", "minLength": 1, "maxLength": 500 },
        "issue_state": { "enum": ["open", "closed"] },
        "issue_url": { "type": "string", "maxLength": 512 },
        "sync_status": { "enum": ["added", "updated", "unchanged"] },
        "task_id": { "type": "string", "minLength": 1, "maxLength": 96 },
        "task_title": { "type": "string", "minLength": 1, "maxLength": 240 },
        "task_status": { "enum": ["open", "claimed", "submitted", "accepted"] },
        "claim_id": { "type": "string", "minLength": 1, "maxLength": 120 },
        "claim_endpoint": { "type": "string", "minLength": 1, "maxLength": 240 },
        "task_protocol_url": { "type": "string", "minLength": 1, "maxLength": 512 },
        "action_endpoint": { "type": "string", "minLength": 1, "maxLength": 240 },
        "reward_cents": { "type": "integer", "minimum": 0 },
        "reward_mrg": { "type": "number", "minimum": 0 },
        "estimated_hours": { "type": "number", "minimum": 0 },
        "required_worker_kind": { "enum": ["human", "agent", "hybrid"] },
        "suggested_agent_type": { "type": "string", "maxLength": 120 },
        "routing": { "$ref": "#/$defs/routing" }
      }
    },
    "routing": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "task_id", "issue_number", "title", "lane", "status", "ready", "reward_cents", "required_worker_kind", "recommended_next_action", "match_score"],
      "properties": {
        "id": { "type": "string", "minLength": 1, "maxLength": 160 },
        "task_id": { "type": "string", "minLength": 1, "maxLength": 96 },
        "issue_number": { "type": "integer", "minimum": 0 },
        "title": { "type": "string", "minLength": 1, "maxLength": 240 },
        "lane": { "type": "string", "minLength": 1, "maxLength": 160 },
        "status": { "type": "string", "minLength": 1, "maxLength": 80 },
        "ready": { "type": "boolean" },
        "blocked_by": {
          "type": "array",
          "items": { "type": "string", "minLength": 1, "maxLength": 120 }
        },
        "reward_cents": { "type": "integer", "minimum": 0 },
        "required_worker_kind": { "enum": ["human", "agent", "hybrid"] },
        "suggested_agent_type": { "type": "string", "maxLength": 120 },
        "recommended_next_action": {
          "enum": ["publish_bounty", "route_to_agent", "route_hybrid_pair", "invite_contributor", "wait_for_dependencies", "paid"]
        },
        "match_score": { "type": "integer", "minimum": 0, "maximum": 100 },
        "routing_reason": {
          "type": "array",
          "items": { "type": "string", "minLength": 1, "maxLength": 240 }
        },
        "recommended_agent": { "$ref": "#/$defs/recommendedAgent" },
        "recommended_worker": { "$ref": "#/$defs/recommendedWorker" }
      }
    },
    "recommendedAgent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "title", "status", "queue_depth"],
      "properties": {
        "type": { "type": "string", "minLength": 1, "maxLength": 120 },
        "title": { "type": "string", "minLength": 1, "maxLength": 160 },
        "status": { "enum": ["active", "standby"] },
        "queue_depth": { "type": "integer", "minimum": 0 }
      }
    },
    "recommendedWorker": {
      "type": "object",
      "additionalProperties": false,
      "required": ["worker_id", "name", "kind", "reputation_score", "risk_level"],
      "properties": {
        "worker_id": { "type": "string", "minLength": 1, "maxLength": 160 },
        "name": { "type": "string", "minLength": 1, "maxLength": 160 },
        "kind": { "enum": ["human", "agent", "hybrid"] },
        "reputation_score": { "type": "integer", "minimum": 0, "maximum": 100 },
        "risk_level": { "enum": ["low", "medium", "high"] }
      }
    }
  }
}
