{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mergeos.shop/protocol/token-launch-brief.v1.schema.json",
  "title": "MergeOS Token Launch Brief v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "protocol_version",
    "kind",
    "brief_id",
    "status",
    "launch_type",
    "project_title",
    "project_summary",
    "research_signals",
    "ledger_entry",
    "ledger_proof_url",
    "live_feed_url",
    "created_at"
  ],
  "properties": {
    "protocol_version": { "const": "mergeos.token-launch-brief.v1" },
    "kind": { "const": "token_launch_brief" },
    "brief_id": { "type": "string", "minLength": 5, "maxLength": 80 },
    "status": { "enum": ["research_pending", "approved", "rejected", "needs_more_evidence"] },
    "launch_type": { "enum": ["airdrop", "presale"] },
    "project_title": { "type": "string", "minLength": 6, "maxLength": 140 },
    "project_summary": { "type": "string", "minLength": 24, "maxLength": 1000 },
    "repository_url": { "type": "string", "format": "uri", "maxLength": 500 },
    "allocation_policy": { "type": "string", "maxLength": 260 },
    "proof_policy": { "type": "string", "maxLength": 260 },
    "wallet_policy": { "type": "string", "maxLength": 260 },
    "risk_notes": { "type": "string", "maxLength": 260 },
    "research_signals": {
      "type": "array",
      "minItems": 1,
      "maxItems": 12,
      "items": { "type": "string", "minLength": 2, "maxLength": 80 }
    },
    "ledger_entry": {
      "type": "object",
      "additionalProperties": true,
      "required": ["sequence", "type", "from_account", "to_account", "amount_cents", "reference", "previous_hash", "entry_hash", "created_at"],
      "properties": {
        "sequence": { "type": "integer", "minimum": 1 },
        "type": { "const": "token_launch_brief" },
        "from_account": { "type": "string", "minLength": 1, "maxLength": 160 },
        "to_account": { "type": "string", "minLength": 1, "maxLength": 160 },
        "amount_cents": { "type": "integer", "minimum": 0 },
        "reference": { "type": "string", "minLength": 1, "maxLength": 512 },
        "previous_hash": { "type": "string", "minLength": 64, "maxLength": 64, "pattern": "^[0-9a-fA-F]{64}$" },
        "entry_hash": { "type": "string", "minLength": 64, "maxLength": 64, "pattern": "^[0-9a-fA-F]{64}$" },
        "created_at": { "type": "string", "format": "date-time" }
      }
    },
    "ledger_proof_url": { "type": "string", "minLength": 1, "maxLength": 240 },
    "live_feed_url": { "type": "string", "minLength": 1, "maxLength": 240 },
    "created_at": { "type": "string", "format": "date-time" }
  }
}
