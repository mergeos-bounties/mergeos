{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mergeos.shop/protocol/escrow.v1.schema.json",
  "title": "MergeOS Escrow v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["protocol_version", "kind", "project_id", "project_title", "token_symbol", "release_status", "budget_cents", "fee_cents", "work_pool_cents", "project_reserve_cents", "task_reserve_cents", "task_payment_cents", "manual_credit_cents", "released_cents", "remaining_cents", "overdrawn_cents", "unallocated_cents", "paid_task_count", "open_task_count", "updated_at", "tasks"],
  "properties": {
    "protocol_version": { "const": "mergeos.escrow.v1" },
    "kind": { "const": "escrow" },
    "project_id": { "type": "string", "minLength": 1, "maxLength": 96 },
    "project_title": { "type": "string", "maxLength": 240 },
    "token_symbol": { "type": "string", "minLength": 1, "maxLength": 16 },
    "release_status": { "enum": ["funded", "releasing", "released", "overdrawn"] },
    "budget_cents": { "type": "integer", "minimum": 0 },
    "fee_cents": { "type": "integer", "minimum": 0 },
    "work_pool_cents": { "type": "integer", "minimum": 0 },
    "project_reserve_cents": { "type": "integer", "minimum": 0 },
    "task_reserve_cents": { "type": "integer", "minimum": 0 },
    "task_payment_cents": { "type": "integer", "minimum": 0 },
    "manual_credit_cents": { "type": "integer", "minimum": 0 },
    "released_cents": { "type": "integer", "minimum": 0 },
    "remaining_cents": { "type": "integer", "minimum": 0 },
    "overdrawn_cents": { "type": "integer", "minimum": 0 },
    "unallocated_cents": { "type": "integer", "minimum": 0 },
    "paid_task_count": { "type": "integer", "minimum": 0 },
    "open_task_count": { "type": "integer", "minimum": 0 },
    "updated_at": { "type": "string", "format": "date-time" },
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["task_id", "issue_number", "title", "status", "release_status", "reward_cents", "paid_cents", "remaining_cents", "overpaid_cents", "updated_at"],
        "properties": {
          "task_id": { "type": "string", "minLength": 1, "maxLength": 96 },
          "issue_number": { "type": "integer", "minimum": 0 },
          "title": { "type": "string", "minLength": 1, "maxLength": 240 },
          "status": { "enum": ["open", "claimed", "submitted", "accepted"] },
          "release_status": { "enum": ["reserved", "partial", "released", "overpaid"] },
          "reward_cents": { "type": "integer", "minimum": 0 },
          "paid_cents": { "type": "integer", "minimum": 0 },
          "remaining_cents": { "type": "integer", "minimum": 0 },
          "overpaid_cents": { "type": "integer", "minimum": 0 },
          "worker_id": { "type": "string", "maxLength": 160 },
          "proof_hash": { "type": "string", "maxLength": 128 },
          "issue_url": { "type": "string", "maxLength": 512 },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      }
    }
  }
}
