{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mergeos.shop/protocol/task-submission.v1.schema.json",
  "title": "MergeOS Task Submission v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["protocol_version", "kind", "id", "claim_id", "task_id", "project_id", "title", "status", "worker_kind", "worker_id", "submitted_at", "task"],
  "properties": {
    "protocol_version": { "const": "mergeos.task-submission.v1" },
    "kind": { "const": "task_submission" },
    "id": { "type": "string", "minLength": 1, "maxLength": 200 },
    "claim_id": { "type": "string", "minLength": 1, "maxLength": 160 },
    "task_id": { "type": "string", "minLength": 1, "maxLength": 96 },
    "project_id": { "type": "string", "minLength": 1, "maxLength": 96 },
    "issue_number": { "type": "integer", "minimum": 0 },
    "title": { "type": "string", "minLength": 1, "maxLength": 240 },
    "status": { "const": "submitted" },
    "worker_kind": { "enum": ["human", "agent", "hybrid"] },
    "worker_id": { "type": "string", "minLength": 1, "maxLength": 200 },
    "agent_type": { "type": "string", "maxLength": 160 },
    "pull_request_url": { "type": "string", "maxLength": 512 },
    "review_evidence_url": { "type": "string", "maxLength": 512 },
    "review_notes": { "type": "string", "maxLength": 2000 },
    "submitted_at": { "type": "string", "format": "date-time" },
    "task": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "project_id", "issue_number", "title", "acceptance", "reward_cents", "required_worker_kind", "suggested_agent_type", "status", "created_at", "submitted_at"],
      "properties": {
        "id": { "type": "string", "minLength": 1, "maxLength": 96 },
        "project_id": { "type": "string", "minLength": 1, "maxLength": 96 },
        "issue_number": { "type": "integer", "minimum": 0 },
        "title": { "type": "string", "minLength": 1, "maxLength": 240 },
        "acceptance": { "type": "string", "maxLength": 2000 },
        "reward_cents": { "type": "integer", "minimum": 0 },
        "required_worker_kind": { "enum": ["human", "agent", "hybrid"] },
        "suggested_agent_type": { "type": "string", "maxLength": 160 },
        "bounty_type": { "type": "string", "maxLength": 120 },
        "status": { "const": "accepted" },
        "worker_kind": { "enum": ["human", "agent", "hybrid"] },
        "worker_id": { "type": "string", "maxLength": 200 },
        "agent_type": { "type": "string", "maxLength": 160 },
        "proof_hash": { "type": "string", "maxLength": 160 },
        "issue_url": { "type": "string", "maxLength": 512 },
        "issue_state": { "type": "string", "maxLength": 80 },
        "pull_request_url": { "type": "string", "maxLength": 512 },
        "review_evidence_url": { "type": "string", "maxLength": 512 },
        "review_notes": { "type": "string", "maxLength": 2000 },
        "created_at": { "type": "string", "format": "date-time" },
        "accepted_at": { "type": "string", "format": "date-time" },
        "submitted_at": { "type": "string", "format": "date-time" }
      }
    }
  }
}
