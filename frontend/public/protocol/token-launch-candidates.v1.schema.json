{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mergeos.shop/protocol/token-launch-candidates.v1.schema.json",
  "title": "MergeOS Token Launch Candidates v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["protocol_version", "kind", "launch_type_filter", "stats", "candidates"],
  "properties": {
    "protocol_version": { "const": "mergeos.token-launch-candidates.v1" },
    "kind": { "const": "token_launch_candidates" },
    "launch_type_filter": {
      "enum": ["all", "airdrop", "presale"],
      "description": "The launch lane applied to this response. Counts are scoped to this lane when filtered."
    },
    "stats": {
      "type": "object",
      "additionalProperties": false,
      "required": ["candidate_count", "airdrop_count", "presale_count", "ready_count", "review_count", "hold_count"],
      "properties": {
        "candidate_count": { "type": "integer", "minimum": 0 },
        "airdrop_count": { "type": "integer", "minimum": 0 },
        "presale_count": { "type": "integer", "minimum": 0 },
        "ready_count": { "type": "integer", "minimum": 0 },
        "review_count": { "type": "integer", "minimum": 0 },
        "hold_count": { "type": "integer", "minimum": 0 },
        "updated_at": { "type": "string", "format": "date-time" }
      }
    },
    "candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "candidate_id",
          "project_id",
          "project_title",
          "recommended_launch_types",
          "decision_launch_type",
          "decision_state",
          "decision_summary",
          "research_source",
          "brief",
          "work_pool_mrg",
          "open_task_count",
          "accepted_task_count",
          "research_score",
          "proof_signals",
          "decision_options",
          "readiness_gates",
          "next_action",
          "gate_summary",
          "proof_policy",
          "marketplace_url",
          "created_at"
        ],
        "properties": {
          "candidate_id": { "type": "string", "maxLength": 80 },
          "project_id": { "type": "string", "maxLength": 80 },
          "project_title": { "type": "string", "maxLength": 160 },
          "recommended_launch_types": {
            "type": "array",
            "items": { "enum": ["airdrop", "presale"] }
          },
          "decision_launch_type": {
            "enum": ["airdrop", "presale"],
            "description": "The launch lane used for readiness gates, decision options, and next_action."
          },
          "decision_state": {
            "enum": ["ready", "review", "hold"],
            "description": "The overall candidate decision state derived from readiness gates."
          },
          "decision_summary": {
            "type": "string",
            "minLength": 12,
            "maxLength": 260,
            "description": "A short CEO-readable explanation of why the candidate is ready, needs review, or should hold."
          },
          "research_source": { "type": "string", "maxLength": 500 },
          "brief": { "type": "string", "maxLength": 1000 },
          "work_pool_mrg": { "type": "integer", "minimum": 0 },
          "open_task_count": { "type": "integer", "minimum": 0 },
          "accepted_task_count": { "type": "integer", "minimum": 0 },
          "research_score": { "type": "integer", "minimum": 0, "maximum": 100 },
          "proof_signals": {
            "type": "array",
            "items": { "type": "string", "minLength": 1, "maxLength": 80 }
          },
          "decision_options": {
            "type": "array",
            "minItems": 3,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["key", "label", "tone", "proof_policy", "risk_notes"],
              "properties": {
                "key": { "enum": ["approve", "needs_evidence", "reject"] },
                "label": { "type": "string", "minLength": 1, "maxLength": 40 },
                "tone": { "enum": ["approve", "evidence", "reject"] },
                "proof_policy": { "type": "string", "minLength": 1, "maxLength": 500 },
                "risk_notes": { "type": "string", "minLength": 1, "maxLength": 500 }
              }
            }
          },
          "readiness_gates": {
            "type": "array",
            "minItems": 3,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["key", "label", "state", "value", "evidence"],
              "properties": {
                "key": { "type": "string", "minLength": 1, "maxLength": 40 },
                "label": { "type": "string", "minLength": 1, "maxLength": 40 },
                "state": { "enum": ["ready", "review", "hold"] },
                "value": { "type": "string", "minLength": 1, "maxLength": 120 },
                "evidence": { "type": "string", "minLength": 1, "maxLength": 260 }
              }
            }
          },
          "next_action": { "type": "string", "minLength": 12, "maxLength": 260 },
          "gate_summary": { "type": "string", "maxLength": 240 },
          "proof_policy": { "type": "string", "maxLength": 500 },
          "marketplace_url": { "type": "string", "maxLength": 200 },
          "created_at": { "type": "string", "format": "date-time" }
        }
      }
    }
  }
}
