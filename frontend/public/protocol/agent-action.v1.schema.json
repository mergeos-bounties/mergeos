{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mergeos.shop/protocol/agent-action.v1.schema.json",
  "title": "MergeOS Agent Action v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["protocol_version", "kind", "action_id", "project_id", "action", "agent_type", "status", "duration_millis", "received_at", "log"],
  "$defs": {
    "contextUrls": {
      "type": "array",
      "maxItems": 8,
      "items": { "type": "string", "minLength": 1, "maxLength": 512 }
    },
    "packetText": {
      "type": "array",
      "maxItems": 12,
      "items": { "type": "string", "minLength": 1, "maxLength": 220 }
    },
    "checks": {
      "type": "array",
      "maxItems": 12,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "status"],
        "properties": {
          "name": { "type": "string", "minLength": 1, "maxLength": 120 },
          "status": { "enum": ["passed", "failed", "warning", "running", "skipped"] },
          "summary": { "type": "string", "maxLength": 260 },
          "reference_url": { "type": "string", "maxLength": 512 }
        }
      }
    }
  },
  "properties": {
    "protocol_version": { "const": "mergeos.agent-action.v1" },
    "kind": { "const": "agent_action" },
    "action_id": { "type": "string", "minLength": 1, "maxLength": 96 },
    "project_id": { "type": "string", "minLength": 1, "maxLength": 96 },
    "claim_id": { "type": "string", "minLength": 1, "maxLength": 160 },
    "bounty_id": { "type": "string", "minLength": 1, "maxLength": 160 },
    "action": { "enum": ["review", "test", "generate", "deploy", "scan"] },
    "agent_type": { "type": "string", "minLength": 1, "maxLength": 160 },
    "status": { "enum": ["received", "running", "processed", "needs_review", "failed"] },
    "repository": { "type": "string", "maxLength": 240 },
    "pull_number": { "type": "integer", "minimum": 0 },
    "reference_url": { "type": "string", "maxLength": 512 },
    "labels": {
      "type": "array",
      "maxItems": 12,
      "items": { "type": "string", "minLength": 1, "maxLength": 160 }
    },
    "context_urls": { "$ref": "#/$defs/contextUrls" },
    "evidence": { "$ref": "#/$defs/packetText" },
    "runbook": { "$ref": "#/$defs/packetText" },
    "checks": { "$ref": "#/$defs/checks" },
    "duration_millis": { "type": "integer", "minimum": 0 },
    "received_at": { "type": "string", "format": "date-time" },
    "completed_at": { "type": "string", "format": "date-time" },
    "log": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "event_name", "status", "status_code", "duration_millis", "received_at"],
      "properties": {
        "id": { "type": "string", "minLength": 1, "maxLength": 96 },
        "delivery_id": { "type": "string", "maxLength": 160 },
        "event_name": { "const": "agent_action" },
        "action": { "enum": ["review", "test", "generate", "deploy", "scan"] },
        "repository": { "type": "string", "maxLength": 240 },
        "pull_number": { "type": "integer", "minimum": 0 },
        "sender": { "type": "string", "maxLength": 200 },
        "status": { "enum": ["received", "running", "processed", "needs_review", "failed"] },
        "status_code": { "type": "integer", "minimum": 100 },
        "error": { "type": "string", "maxLength": 1000 },
        "comment_url": { "type": "string", "maxLength": 512 },
        "key_id": { "type": "string", "maxLength": 96 },
        "labels": {
          "type": "array",
          "maxItems": 12,
          "items": { "type": "string", "minLength": 1, "maxLength": 160 }
        },
        "context_urls": { "$ref": "#/$defs/contextUrls" },
        "evidence": { "$ref": "#/$defs/packetText" },
        "runbook": { "$ref": "#/$defs/packetText" },
        "checks": { "$ref": "#/$defs/checks" },
        "duration_millis": { "type": "integer", "minimum": 0 },
        "received_at": { "type": "string", "format": "date-time" },
        "completed_at": { "type": "string", "format": "date-time" }
      }
    }
  }
}
