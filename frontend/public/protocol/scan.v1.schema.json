{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mergeos.shop/protocol/scan.v1.schema.json",
  "title": "MergeOS Repository Scan v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["protocol_version", "kind", "id", "project_id", "status", "stats", "findings"],
  "properties": {
    "protocol_version": { "const": "mergeos.scan.v1" },
    "kind": { "const": "repository_scan" },
    "id": { "type": "string", "minLength": 3, "maxLength": 120 },
    "project_id": { "type": "string", "minLength": 3, "maxLength": 96 },
    "project_title": { "type": "string", "maxLength": 240 },
    "status": { "enum": ["unavailable", "ready", "failed"] },
    "summary": { "type": "string", "maxLength": 2000 },
    "source_repository": { "type": "string", "maxLength": 512 },
    "updated_at": { "type": "string", "format": "date-time" },
    "stats": {
      "type": "object",
      "additionalProperties": false,
      "required": ["file_count", "scanned_files", "finding_count"],
      "properties": {
        "file_count": { "type": "integer", "minimum": 0 },
        "scanned_files": { "type": "integer", "minimum": 0 },
        "skipped_files": { "type": "integer", "minimum": 0 },
        "dependency_files": { "type": "integer", "minimum": 0 },
        "finding_count": { "type": "integer", "minimum": 0 },
        "suggested_task_count": { "type": "integer", "minimum": 0 }
      }
    },
    "languages": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["language", "file_count"],
        "properties": {
          "language": { "type": "string", "minLength": 1, "maxLength": 80 },
          "extension": { "type": "string", "maxLength": 20 },
          "file_count": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "ecosystem", "package_count"],
        "properties": {
          "path": { "type": "string", "minLength": 1, "maxLength": 512 },
          "ecosystem": { "type": "string", "minLength": 1, "maxLength": 80 },
          "package_count": { "type": "integer", "minimum": 0 },
          "has_lockfile": { "type": "boolean" }
        }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "severity", "category", "title", "signal"],
        "properties": {
          "id": { "type": "string", "minLength": 1, "maxLength": 120 },
          "severity": { "enum": ["low", "medium", "high", "critical"] },
          "category": { "type": "string", "minLength": 1, "maxLength": 120 },
          "title": { "type": "string", "minLength": 1, "maxLength": 240 },
          "body": { "type": "string", "maxLength": 1000 },
          "path": { "type": "string", "maxLength": 512 },
          "line": { "type": "integer", "minimum": 0 },
          "signal": { "type": "string", "minLength": 1, "maxLength": 120 }
        }
      }
    },
    "suggested_tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "source_finding_id", "signal", "title", "severity", "lane", "estimated_reward_cents", "worker_kind", "ready_for_bounty", "funding_packet"],
        "properties": {
          "id": { "type": "string", "minLength": 1, "maxLength": 120 },
          "source_finding_id": { "type": "string", "minLength": 1, "maxLength": 120 },
          "signal": { "type": "string", "minLength": 1, "maxLength": 120 },
          "title": { "type": "string", "minLength": 1, "maxLength": 240 },
          "body": { "type": "string", "maxLength": 1000 },
          "severity": { "enum": ["low", "medium", "high", "critical"] },
          "lane": { "type": "string", "minLength": 1, "maxLength": 80 },
          "path": { "type": "string", "maxLength": 512 },
          "estimated_reward_cents": { "type": "integer", "minimum": 0 },
          "estimated_hours": { "type": "number", "minimum": 0 },
          "worker_kind": { "enum": ["human", "agent", "hybrid"] },
          "suggested_agent_type": { "type": "string", "maxLength": 120 },
          "ready_for_bounty": { "type": "boolean" },
          "acceptance_criteria": {
            "type": "array",
            "items": { "type": "string", "minLength": 1, "maxLength": 500 }
          },
          "evidence_required": {
            "type": "array",
            "items": { "type": "string", "minLength": 1, "maxLength": 120 }
          },
          "funding_packet": {
            "type": "object",
            "additionalProperties": false,
            "required": ["status", "can_fund", "recommended_reward_cents", "recommended_funding_cents", "fund_payload", "paypal_order_payload", "evidence_checklist"],
            "properties": {
              "status": { "enum": ["ready", "already_funded", "needs_review", "blocked"] },
              "can_fund": { "type": "boolean" },
              "recommended_reward_cents": { "type": "integer", "minimum": 0 },
              "recommended_funding_cents": { "type": "integer", "minimum": 0 },
              "fund_endpoint": { "type": "string", "maxLength": 512 },
              "paypal_order_endpoint": { "type": "string", "maxLength": 512 },
              "fund_payload": { "type": "object" },
              "paypal_order_payload": { "type": "object" },
              "evidence_checklist": {
                "type": "array",
                "items": { "type": "string", "minLength": 1, "maxLength": 120 }
              }
            }
          }
        }
      }
    },
    "metadata": { "type": "object" }
  }
}
