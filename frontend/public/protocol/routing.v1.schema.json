{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mergeos.shop/protocol/routing.v1.schema.json",
  "title": "MergeOS Project Routing v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["protocol_version", "kind", "project_id", "project_title", "status", "summary", "stats", "lanes", "routes", "updated_at"],
  "properties": {
    "protocol_version": { "const": "mergeos.routing.v1" },
    "kind": { "const": "project_routing" },
    "project_id": { "type": "string", "minLength": 1, "maxLength": 96 },
    "project_title": { "type": "string", "minLength": 1, "maxLength": 240 },
    "status": { "enum": ["waiting", "routing", "ready", "blocked", "complete"] },
    "summary": { "type": "string", "minLength": 1, "maxLength": 1000 },
    "stats": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "task_count",
        "ready_count",
        "blocked_count",
        "contributor_candidate_count",
        "agent_candidate_count",
        "human_lane_count",
        "agent_lane_count",
        "hybrid_lane_count"
      ],
      "properties": {
        "task_count": { "type": "integer", "minimum": 0 },
        "ready_count": { "type": "integer", "minimum": 0 },
        "blocked_count": { "type": "integer", "minimum": 0 },
        "contributor_candidate_count": { "type": "integer", "minimum": 0 },
        "agent_candidate_count": { "type": "integer", "minimum": 0 },
        "human_lane_count": { "type": "integer", "minimum": 0 },
        "agent_lane_count": { "type": "integer", "minimum": 0 },
        "hybrid_lane_count": { "type": "integer", "minimum": 0 }
      }
    },
    "lanes": {
      "type": "array",
      "items": { "$ref": "#/$defs/lane" }
    },
    "routes": {
      "type": "array",
      "items": { "$ref": "#/$defs/route" }
    },
    "updated_at": { "type": "string", "format": "date-time" }
  },
  "$defs": {
    "lane": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "worker_kind", "recommended_for", "task_count", "ready_count", "blocked_count", "reward_cents", "status"],
      "properties": {
        "id": { "type": "string", "minLength": 1, "maxLength": 160 },
        "title": { "type": "string", "minLength": 1, "maxLength": 160 },
        "worker_kind": { "enum": ["human", "agent", "hybrid"] },
        "agent_type": { "type": "string", "maxLength": 120 },
        "recommended_for": { "type": "string", "minLength": 1, "maxLength": 240 },
        "task_count": { "type": "integer", "minimum": 0 },
        "ready_count": { "type": "integer", "minimum": 0 },
        "blocked_count": { "type": "integer", "minimum": 0 },
        "reward_cents": { "type": "integer", "minimum": 0 },
        "status": { "enum": ["ready", "blocked", "complete"] }
      }
    },
    "route": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "task_id",
        "claim_id",
        "issue_number",
        "title",
        "lane",
        "status",
        "ready",
        "reward_cents",
        "required_worker_kind",
        "protocol_url",
        "recommended_next_action",
        "match_score",
        "routing_packet"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1, "maxLength": 160 },
        "task_id": { "type": "string", "minLength": 1, "maxLength": 96 },
        "claim_id": { "type": "string", "minLength": 1, "maxLength": 120 },
        "issue_number": { "type": "integer", "minimum": 0 },
        "title": { "type": "string", "minLength": 1, "maxLength": 240 },
        "lane": { "type": "string", "minLength": 1, "maxLength": 160 },
        "status": { "type": "string", "minLength": 1, "maxLength": 80 },
        "ready": { "type": "boolean" },
        "blocked_by": {
          "type": "array",
          "items": { "type": "string", "minLength": 1, "maxLength": 120 }
        },
        "reward_cents": { "type": "integer", "minimum": 0 },
        "required_worker_kind": { "enum": ["human", "agent", "hybrid"] },
        "suggested_agent_type": { "type": "string", "maxLength": 120 },
        "protocol_url": { "type": "string", "minLength": 1, "maxLength": 512 },
        "recommended_next_action": {
          "enum": ["publish_bounty", "route_to_agent", "route_hybrid_pair", "invite_contributor", "review_evidence", "wait_for_dependencies", "paid"]
        },
        "match_score": { "type": "integer", "minimum": 0, "maximum": 100 },
        "routing_reason": {
          "type": "array",
          "items": { "type": "string", "minLength": 1, "maxLength": 240 }
        },
        "recommended_agent": { "$ref": "#/$defs/recommendedAgent" },
        "recommended_worker": { "$ref": "#/$defs/recommendedWorker" },
        "routing_packet": { "$ref": "#/$defs/routingPacket" }
      }
    },
    "routingPacket": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action", "method", "endpoint", "context_urls", "runbook"],
      "properties": {
        "action": {
          "enum": ["publish_bounty", "route_to_agent", "route_hybrid_pair", "invite_contributor", "review_evidence", "wait_for_dependencies", "paid"]
        },
        "method": { "enum": ["GET", "POST"] },
        "endpoint": { "type": "string", "minLength": 1, "maxLength": 512 },
        "payload": {
          "type": "object",
          "additionalProperties": true
        },
        "context_urls": {
          "type": "object",
          "additionalProperties": { "type": "string", "maxLength": 512 }
        },
        "runbook": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/runbookStep" }
        },
        "output_contracts": {
          "type": "array",
          "items": { "$ref": "#/$defs/outputContract" }
        }
      }
    },
    "runbookStep": {
      "type": "object",
      "additionalProperties": false,
      "required": ["step", "action", "label", "method", "endpoint"],
      "properties": {
        "step": { "type": "integer", "minimum": 1 },
        "action": { "type": "string", "minLength": 1, "maxLength": 120 },
        "label": { "type": "string", "minLength": 1, "maxLength": 180 },
        "method": { "enum": ["GET", "POST", "PATCH", "DELETE"] },
        "endpoint": { "type": "string", "minLength": 1, "maxLength": 512 }
      }
    },
    "outputContract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action", "artifact_kind", "output_endpoint", "output_protocol", "output_protocol_url"],
      "properties": {
        "action": { "type": "string", "minLength": 1, "maxLength": 120 },
        "artifact_kind": { "type": "string", "minLength": 1, "maxLength": 120 },
        "output_endpoint": { "type": "string", "minLength": 1, "maxLength": 512 },
        "output_protocol": { "type": "string", "minLength": 1, "maxLength": 120 },
        "output_protocol_url": { "type": "string", "minLength": 1, "maxLength": 512 },
        "public_url": { "type": "string", "maxLength": 512 }
      }
    },
    "recommendedAgent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "title", "status", "queue_depth"],
      "properties": {
        "type": { "type": "string", "minLength": 1, "maxLength": 120 },
        "title": { "type": "string", "minLength": 1, "maxLength": 160 },
        "status": { "enum": ["active", "standby"] },
        "queue_depth": { "type": "integer", "minimum": 0 }
      }
    },
    "recommendedWorker": {
      "type": "object",
      "additionalProperties": false,
      "required": ["worker_id", "name", "kind", "reputation_score", "risk_level"],
      "properties": {
        "worker_id": { "type": "string", "minLength": 1, "maxLength": 160 },
        "name": { "type": "string", "minLength": 1, "maxLength": 160 },
        "kind": { "enum": ["human", "agent", "hybrid"] },
        "reputation_score": { "type": "integer", "minimum": 0, "maximum": 100 },
        "risk_level": { "enum": ["low", "medium", "high"] }
      }
    }
  }
}
