{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mergeos.shop/protocol/workflow.v1.schema.json",
  "title": "MergeOS Workflow v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["protocol_version", "kind", "id", "project_id", "nodes", "edges"],
  "properties": {
    "protocol_version": { "const": "mergeos.workflow.v1" },
    "kind": { "const": "workflow" },
    "id": { "type": "string", "minLength": 3, "maxLength": 96 },
    "project_id": { "type": "string", "minLength": 3, "maxLength": 96 },
    "status": { "enum": ["planned", "active", "blocked", "ready", "released"] },
    "progress": { "type": "integer", "minimum": 0, "maximum": 100 },
    "current_step": {
      "enum": [
        "repo_import",
        "issue_scan",
        "task_generation",
        "reward_estimation",
        "contributor_routing",
        "pr_review",
        "deployment_validation"
      ]
    },
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "task_id", "title", "lane", "status"],
        "properties": {
          "id": { "type": "string", "minLength": 1, "maxLength": 96 },
          "task_id": { "type": "string", "minLength": 1, "maxLength": 96 },
          "issue_number": { "type": "integer", "minimum": 0 },
          "title": { "type": "string", "minLength": 1, "maxLength": 240 },
          "lane": { "enum": ["implementation", "backend", "design", "validation", "deployment", "agent"] },
          "status": { "enum": ["open", "claimed", "submitted", "accepted", "blocked", "ready"] },
          "reward_mrg": { "type": "number", "minimum": 0 },
          "estimated_hours": { "type": "number", "minimum": 0 },
          "worker_kind": { "enum": ["human", "agent", "hybrid"] },
          "agent_type": { "type": "string", "maxLength": 120 },
          "issue_url": { "type": "string", "maxLength": 512 },
          "dependencies": {
            "type": "array",
            "items": { "type": "string", "minLength": 1, "maxLength": 96 }
          }
        }
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["from", "to", "relation"],
        "properties": {
          "from": { "type": "string", "minLength": 1, "maxLength": 96 },
          "to": { "type": "string", "minLength": 1, "maxLength": 96 },
          "relation": { "type": "string", "minLength": 1, "maxLength": 120 }
        }
      }
    },
    "stages": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "title", "summary", "status", "artifact_kind", "output_endpoint", "output_protocol", "output_protocol_url", "context_urls", "produced_count", "updated_at"],
        "properties": {
          "id": {
            "enum": [
              "repo_import",
              "issue_scan",
              "task_generation",
              "reward_estimation",
              "contributor_routing",
              "pr_review",
              "deployment_validation"
            ]
          },
          "title": { "type": "string", "minLength": 1, "maxLength": 160 },
          "summary": { "type": "string", "minLength": 1, "maxLength": 1000 },
          "status": { "enum": ["pending", "in_progress", "complete"] },
          "tone": { "enum": ["green", "blue", "amber", "red", "gray"] },
          "artifact_kind": {
            "enum": [
              "repository_context",
              "repository_scan",
              "task_protocol",
              "project_estimate",
              "routing_plan",
              "agent_action",
              "deployment_evidence",
              "workflow_stage"
            ]
          },
          "input_endpoint": { "type": "string", "minLength": 1, "maxLength": 512 },
          "output_endpoint": { "type": "string", "minLength": 1, "maxLength": 512 },
          "output_protocol": {
            "enum": [
              "mergeos.agent-action.v1",
              "mergeos.ai-workflow.v1",
              "mergeos.deployment.v1",
              "mergeos.estimate.v1",
              "mergeos.repo-import.v1",
              "mergeos.routing.v1",
              "mergeos.scan.v1",
              "mergeos.task.v1",
              "mergeos.workflow.v1"
            ]
          },
          "output_protocol_url": { "type": "string", "minLength": 1, "maxLength": 512 },
          "action_endpoint": { "type": "string", "minLength": 1, "maxLength": 512 },
          "context_urls": {
            "type": "object",
            "minProperties": 1,
            "propertyNames": { "type": "string", "minLength": 1, "maxLength": 80 },
            "additionalProperties": { "type": "string", "minLength": 1, "maxLength": 512 }
          },
          "checklist": {
            "type": "array",
            "minItems": 1,
            "maxItems": 8,
            "items": { "type": "string", "minLength": 1, "maxLength": 240 }
          },
          "output_ids": {
            "type": "array",
            "items": { "type": "string", "minLength": 1, "maxLength": 160 }
          },
          "produced_count": { "type": "integer", "minimum": 0 },
          "reference": { "type": "string", "maxLength": 512 },
          "url": { "type": "string", "maxLength": 512 },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      }
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "stage_id", "title", "status", "required"],
        "properties": {
          "id": { "type": "string", "minLength": 3, "maxLength": 120 },
          "stage_id": {
            "enum": [
              "repo_import",
              "issue_scan",
              "task_generation",
              "reward_estimation",
              "contributor_routing",
              "pr_review",
              "deployment_validation"
            ]
          },
          "title": { "type": "string", "minLength": 1, "maxLength": 160 },
          "status": { "enum": ["pending", "running", "passed", "blocked"] },
          "required": { "type": "boolean" },
          "summary": { "type": "string", "maxLength": 1000 }
        }
      }
    },
    "next_actions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "type", "label", "target_step"],
        "properties": {
          "id": { "type": "string", "minLength": 3, "maxLength": 120 },
          "type": {
            "enum": [
              "import_repository",
              "sync_repository_issues",
              "evaluate_scope",
              "submit_proposal",
              "claim_with_agent",
              "record_agent_review",
              "record_deployment_evidence"
            ]
          },
          "label": { "type": "string", "minLength": 1, "maxLength": 160 },
          "target_step": {
            "enum": [
              "repo_import",
              "issue_scan",
              "task_generation",
              "reward_estimation",
              "contributor_routing",
              "pr_review",
              "deployment_validation"
            ]
          },
          "target_node_id": { "type": "string", "minLength": 1, "maxLength": 96 },
          "task_id": { "type": "string", "minLength": 1, "maxLength": 96 },
          "worker_kind": { "enum": ["human", "agent", "hybrid"] },
          "method": { "enum": ["GET", "POST", "PATCH", "DELETE"] },
          "endpoint": { "type": "string", "minLength": 1, "maxLength": 240 }
        }
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "type", "title", "status", "created_at"],
        "properties": {
          "id": { "type": "string", "minLength": 1, "maxLength": 120 },
          "type": { "type": "string", "minLength": 1, "maxLength": 120 },
          "title": { "type": "string", "minLength": 1, "maxLength": 240 },
          "status": { "type": "string", "minLength": 1, "maxLength": 120 },
          "reference": { "type": "string", "maxLength": 512 },
          "url": { "type": "string", "maxLength": 512 },
          "created_at": { "type": "string", "format": "date-time" }
        }
      }
    },
    "metadata": { "type": "object" }
  }
}
