{
  "protocol_version": "mergeos.architecture.v1",
  "kind": "product_architecture",
  "product": "MergeOS",
  "positioning": "AI software delivery operating system",
  "thesis": "MergeOS turns repositories, issues, technical debt, bug fixes, pull requests, deployments, escrow, contributors, AI agents, token accounting, and public ledger proof into one realtime workflow.",
  "not_a": [
    "traditional freelancer marketplace",
    "standalone IDE",
    "token-only project"
  ],
  "product_vision": {
    "summary": "A workflow layer combining GitHub-style repository context, Stripe-style payment verification, Linear-style task operations, Upwork-style contributor routing, Vercel-style deployment proof, and AI agent execution.",
    "core_loop": [
      "import_repository",
      "scan_issues_with_ai",
      "generate_task_graph",
      "estimate_rewards",
      "fund_escrow",
      "route_contributors_or_agents",
      "review_pull_requests",
      "validate_deployment",
      "release_payment",
      "publish_ledger_proof"
    ],
    "workflow_routes": {
      "import_repository": {
        "page": "/project/new",
        "api": "/api/repos/import",
        "proof_surface": "/live-feed"
      },
      "scan_issues_with_ai": {
        "page": "/repo-import",
        "api": "/api/public/projects/{id}/repo-scan",
        "proof_surface": "/live-feed"
      },
      "generate_task_graph": {
        "page": "/dashboard",
        "api": "/api/projects/{id}/task-graph",
        "proof_surface": "/marketplace#marketplace-bounties"
      },
      "estimate_rewards": {
        "page": "/project/new/budget",
        "api": "/api/projects/{id}/estimate",
        "proof_surface": "/ledger"
      },
      "fund_escrow": {
        "page": "/project/new/review",
        "api": "/api/projects/{id}/escrow",
        "proof_surface": "/contracts"
      },
      "route_contributors_or_agents": {
        "page": "/marketplace",
        "api": "/api/public/protocol/routing",
        "proof_surface": "/marketplace"
      },
      "review_pull_requests": {
        "page": "/dashboard",
        "api": "/api/public/projects/{id}/pull-requests",
        "proof_surface": "/ledger"
      },
      "validate_deployment": {
        "page": "/live-feed",
        "api": "/api/public/protocol/deployment",
        "proof_surface": "/ledger"
      },
      "release_payment": {
        "page": "/dashboard?section=admin",
        "api": "/api/public/protocol/payout-settlement",
        "proof_surface": "/ledger"
      },
      "publish_ledger_proof": {
        "page": "/ledger",
        "api": "/api/public/ledger",
        "proof_surface": "/ledger"
      }
    }
  },
  "repository_architecture": [
    {
      "name": "mergeos-app",
      "role": "Primary product repository",
      "contains": [
        "frontend",
        "backend",
        "dashboards",
        "APIs",
        "SSR",
        "orchestration logic",
        "realtime feeds"
      ],
      "artifact_urls": {
        "primary": "/",
        "protocol": "/system/mergeos-architecture.v1.json",
        "public_reference": "/protocol"
      }
    },
    {
      "name": "mergeos-contracts",
      "role": "Blockchain and treasury repository",
      "contains": [
        "MRG token",
        "escrow contracts",
        "treasury contracts",
        "payout contracts"
      ],
      "artifact_urls": {
        "primary": "/contracts",
        "protocol": "/contracts/solana/mergeos_mrg.v1.idl.json",
        "public_reference": "/contracts/solana/mergeos_mrg.proof-manifest.v1.json"
      }
    },
    {
      "name": "mergeos-sdk",
      "role": "Integration repository",
      "contains": [
        "task APIs",
        "workflow APIs",
        "event APIs",
        "helper libraries",
        "agent run helpers"
      ],
      "artifact_urls": {
        "primary": "/sdk",
        "protocol": "/protocol",
        "public_reference": "/api/public/protocol/manifest"
      }
    },
    {
      "name": "mergeos-protocol",
      "role": "Future open protocol layer",
      "contains": [
        "decentralized execution standards",
        "external AI agent contracts",
        "public integrations",
        "open task manifests"
      ],
      "artifact_urls": {
        "primary": "/protocol",
        "protocol": "/protocol/architecture.v1.schema.json",
        "public_reference": "/system/mergeos-architecture.v1.json"
      }
    }
  ],
  "users": [
    {
      "type": "customers",
      "examples": ["startups", "SaaS companies", "repository owners", "founders"],
      "dashboard": "Customer Dashboard",
      "role_routes": {
        "page": "/dashboard",
        "api": "/api/projects/{id}/dashboard",
        "capabilities": ["project overview", "live PRs", "escrow", "payments", "tasks", "AI logs"]
      }
    },
    {
      "type": "contributors",
      "examples": ["frontend developers", "backend developers", "designers", "QA engineers", "DevOps", "security auditors"],
      "dashboard": "Worker Dashboard",
      "role_routes": {
        "page": "/dashboard?section=worker",
        "api": "/api/workers/me",
        "capabilities": ["claimed tasks", "rewards", "reputation", "proposals"]
      }
    },
    {
      "type": "ai_agents",
      "examples": ["coding agents", "review agents", "testing agents", "deployment agents"],
      "surface": "Agent queue, agent runbooks, and agent run packets",
      "role_routes": {
        "page": "/agents",
        "api": "/api/public/agents/queue",
        "capabilities": ["scan repositories", "generate task packets", "review PRs", "test builds", "validate deployments"]
      }
    },
    {
      "type": "admins",
      "examples": ["treasury operators", "dispute handlers", "moderation", "payout management"],
      "dashboard": "Admin Console",
      "role_routes": {
        "page": "/dashboard?section=admin",
        "api": "/api/admin/ops-queue",
        "capabilities": ["treasury", "users", "disputes", "payouts", "moderation"]
      }
    }
  ],
  "frontend_system": {
    "stack": ["Vue 3", "Vite SSR", "TailwindCSS-compatible design tokens", "WebSockets", "realtime events"],
    "public_pages": ["Homepage", "Marketplace", "Live Feed", "Ledger Logs", "Protocol", "MergeIDE", "Airdrop", "Presale", "Whitepaper"],
    "authenticated_dashboards": ["Customer Dashboard", "Worker Dashboard", "Admin Console"],
    "authenticated_dashboard_urls": {
      "customer_dashboard": {
        "page": "/dashboard",
        "api": "/api/projects/{id}/dashboard",
        "capabilities": ["project overview", "live PRs", "escrow", "payments", "tasks", "AI logs"]
      },
      "worker_dashboard": {
        "page": "/dashboard?section=worker",
        "api": "/api/workers/me",
        "capabilities": ["claimed tasks", "rewards", "reputation", "proposals"]
      },
      "admin_console": {
        "page": "/dashboard?section=admin",
        "api": "/api/admin/ops-queue",
        "capabilities": ["treasury", "users", "disputes", "payouts", "moderation"]
      }
    }
  },
  "backend_system": {
    "role": "Backend coordinates authentication, repositories, AI orchestration, task engine, payment verification, escrow coordination, live notifications, and ledger records.",
    "proposed_stack": ["Go", "Rust-compatible service boundary", "PostgreSQL", "Redis", "GitHub API", "OpenAI API", "WebSocket gateway"],
    "runtime_routes": {
      "authentication": "/api/auth/session",
      "repository_import": "/api/repos/import",
      "ai_orchestration": "/api/projects/{id}/ai-workflow",
      "task_engine": "/api/projects/{id}/task-graph",
      "payment_verification": "/api/payments/order-intents",
      "escrow_coordination": "/api/projects/{id}/escrow",
      "live_notifications": "/api/ws",
      "ledger_system": "/api/public/ledger"
    }
  },
  "ai_layer": {
    "capabilities": [
      "scan repositories",
      "detect bugs",
      "detect technical debt",
      "detect dependency risk",
      "analyze issues",
      "estimate complexity",
      "estimate budget",
      "generate tasks",
      "review pull requests",
      "run security review",
      "validate deployments"
    ],
    "workflow": [
      "Import Repository",
      "Issue Scan",
      "Task Generation",
      "Reward Estimation",
      "Contributor Routing",
      "PR Review",
      "Deployment Validation"
    ],
    "action_routes": {
      "scan_repository": {
        "api": "/api/public/projects/{id}/repo-scan",
        "output_protocol": "mergeos.scan.v1",
        "proof_surface": "/live-feed"
      },
      "analyze_issues": {
        "api": "/api/projects/{id}/ai-workflow",
        "output_protocol": "mergeos.ai-workflow.v1",
        "proof_surface": "/dashboard"
      },
      "generate_tasks": {
        "api": "/api/projects/{id}/task-graph",
        "output_protocol": "mergeos.workflow.v1",
        "proof_surface": "/marketplace#marketplace-bounties"
      },
      "route_workers": {
        "api": "/api/public/protocol/routing",
        "output_protocol": "mergeos.routing.v1",
        "proof_surface": "/marketplace"
      },
      "review_prs": {
        "api": "/api/public/projects/{id}/pull-requests",
        "output_protocol": "mergeos.pr-monitor.v1",
        "proof_surface": "/ledger"
      },
      "test_builds": {
        "api": "/api/public/projects/{id}/ai-workflow",
        "output_protocol": "mergeos.ai-workflow.v1",
        "proof_surface": "/live-feed"
      },
      "validate_deployments": {
        "api": "/api/public/protocol/deployment",
        "output_protocol": "mergeos.deployment.v1",
        "proof_surface": "/ledger"
      }
    }
  },
  "marketplace_system": {
    "role": "Realtime economy for live projects, public bounties, contributor proposals, AI agent lanes, escrow-backed work, and payout proof.",
    "features": ["Live Projects", "Public Bounties", "AI Agents", "Contributor Signals", "Escrow Proof", "Ledger Logs"],
    "feature_routes": {
      "live_projects": {
        "page": "/marketplace#marketplace-projects",
        "api": "/api/public/marketplace",
        "event_type": "project_funded"
      },
      "public_bounties": {
        "page": "/marketplace#marketplace-bounties",
        "api": "/api/public/marketplace",
        "event_type": "task_opened"
      },
      "contributors": {
        "page": "/marketplace#marketplace-contributors",
        "api": "/api/public/marketplace",
        "event_type": "proposal_submitted"
      },
      "ai_agents": {
        "page": "/marketplace#marketplace-agents",
        "api": "/api/public/protocol/agent-queue",
        "event_type": "agent_queue"
      }
    },
    "action_routes": {
      "publish_bounty": {
        "command": "Publish funded bounty from repository scope",
        "api": "/api/projects/{id}/repo-scan/suggested-tasks/{taskID}/fund",
        "output_protocol": "mergeos.repo-task-funding.v1",
        "proof_surface": "/marketplace#marketplace-bounties"
      },
      "submit_proposal": {
        "command": "Submit contributor bid and availability packet",
        "api": "/api/proposals",
        "output_protocol": "mergeos.proposal.v1",
        "proof_surface": "/dashboard?section=worker"
      },
      "claim_task": {
        "command": "Claim public bounty work",
        "api": "/api/tasks/{id}/claim",
        "output_protocol": "mergeos.task-claim.v1",
        "proof_surface": "/live-feed"
      },
      "lease_agent_work": {
        "command": "Lease AI agent queue work before execution",
        "api": "/api/agent-queue/leases",
        "output_protocol": "mergeos.agent-lease.v1",
        "proof_surface": "/agents"
      },
      "submit_evidence": {
        "command": "Submit PR, test, deployment, or agent evidence",
        "api": "/api/tasks/{id}/submit",
        "output_protocol": "mergeos.task-submission.v1",
        "proof_surface": "/ledger"
      }
    }
  },
  "live_feed_system": {
    "role": "Public realtime stream for pull requests, deployments, contributor activity, AI actions, and payout events.",
    "features": ["Live PRs", "Deployments", "Active Contributors", "AI Actions", "Payout Events"],
    "event_routes": {
      "live_prs": {
        "page": "/live-feed",
        "api": "/api/public/live-feed",
        "event_type": "task_submitted",
        "ledger_tab": "Tasks & PRs"
      },
      "deployments": {
        "page": "/live-feed",
        "api": "/api/public/live-feed",
        "event_type": "deployment_status",
        "ledger_tab": "Milestones"
      },
      "contributors": {
        "page": "/live-feed",
        "api": "/api/public/live-feed",
        "event_type": "task_claimed",
        "ledger_tab": "Tasks & PRs"
      },
      "ai_actions": {
        "page": "/live-feed",
        "api": "/api/public/live-feed",
        "event_type": "ai_review",
        "ledger_tab": "AI Actions"
      }
    }
  },
  "ledger_system": {
    "role": "Public transparency log for payouts, escrow events, PR evidence, AI actions, release proof, token mints, and contract references.",
    "features": ["Payouts", "Escrow Events", "PR Events", "AI Actions", "Releases", "Token Events"],
    "proof_routes": {
      "payouts": {
        "page": "/ledger",
        "api": "/api/public/ledger/events",
        "event_type": "ledger_task_payment",
        "proof_api": "/api/public/ledger/proof"
      },
      "escrow_events": {
        "page": "/ledger",
        "api": "/api/public/ledger/events",
        "event_type": "payment_verified",
        "proof_api": "/api/public/ledger/proof"
      },
      "pr_events": {
        "page": "/ledger",
        "api": "/api/public/ledger/events",
        "event_type": "task_submitted",
        "proof_api": "/api/public/ledger/proof"
      },
      "ai_actions": {
        "page": "/ledger",
        "api": "/api/public/ledger/events",
        "event_type": "ai_review",
        "proof_api": "/api/public/ledger/proof"
      },
      "releases": {
        "page": "/ledger",
        "api": "/api/public/ledger/events",
        "event_type": "payout_released",
        "proof_api": "/api/public/ledger/proof"
      }
    }
  },
  "token_economy_system": {
    "role": "MRG token accounting layer for Solana treasury, escrow reserves, airdrop claims, presale reservations, wallet migration, and payout settlement.",
    "features": ["MRG Supply", "Escrow Reserve", "Airdrop Claims", "Presale Reservations", "Wallet Migration", "Payout Settlement", "Solana Proof Manifest"],
    "protocol_routes": {
      "public_supply": {
        "page": "/ledger",
        "api": "/api/public/token-economy",
        "output_protocol": "mergeos.token-economy.v1",
        "proof_surface": "/ledger"
      },
      "airdrop_claims": {
        "page": "/airdrop",
        "api": "/api/airdrop/claims",
        "output_protocol": "mergeos.airdrop-claim.v1",
        "proof_surface": "/api/public/ledger/proof"
      },
      "presale_reservations": {
        "page": "/presale",
        "api": "/api/presale/reservations",
        "output_protocol": "mergeos.presale-reservation.v1",
        "proof_surface": "/api/public/ledger/proof"
      },
      "wallet_migration": {
        "page": "/contracts",
        "api": "/api/wallet/migration",
        "output_protocol": "mergeos.wallet-migration.v1",
        "proof_surface": "/contracts/solana/mergeos_mrg.proof-manifest.v1.json"
      },
      "payout_settlement": {
        "page": "/dashboard",
        "api": "/api/projects/{id}/payouts",
        "output_protocol": "mergeos.payouts.v1",
        "proof_surface": "/ledger"
      },
      "solana_contract": {
        "page": "/contracts",
        "api": "/contracts/solana/mergeos_mrg.v1.idl.json",
        "output_protocol": "mergeos.solana-mrg.v1",
        "proof_surface": "/contracts/solana/mergeos_mrg.proof-manifest.v1.json"
      }
    }
  },
  "public_urls": {
    "system": "/system",
    "marketplace": "/marketplace",
    "live_feed": "/live-feed",
    "ledger": "/ledger",
    "protocol": "/protocol",
    "whitepaper": "/whitepaper",
    "architecture_manifest": "/system/mergeos-architecture.v1.json",
    "marketplace_api": "/api/public/marketplace",
    "live_feed_api": "/api/public/live-feed",
    "agent_queue_api": "/api/public/protocol/agent-queue",
    "ledger_api": "/api/public/ledger",
    "ledger_events_api": "/api/public/ledger/events",
    "ledger_verify_api": "/api/public/ledger/verify",
    "ledger_proof_api": "/api/public/ledger/proof",
    "token_economy_api": "/api/public/token-economy",
    "airdrop_missions_api": "/api/public/airdrop/missions",
    "airdrop_claims_api": "/api/airdrop/claims",
    "presale_reservations_api": "/api/presale/reservations",
    "project_escrow_api": "/api/projects/{id}/escrow",
    "project_payouts_api": "/api/projects/{id}/payouts",
    "solana_mrg_idl": "/contracts/solana/mergeos_mrg.v1.idl.json",
    "solana_mrg_proof_manifest": "/contracts/solana/mergeos_mrg.proof-manifest.v1.json"
  }
}
