{
  "name": "mergeide",
  "displayName": "MergeIDE",
  "version": "0.1.0",
  "private": true,
  "description": "MergeOS task runner and VS Code style workspace bridge for user-selected AI CLIs.",
  "main": "./src/extension.js",
  "bin": {
    "mergeide": "./bin/mergeide.js"
  },
  "scripts": {
    "start": "node ./bin/mergeide.js",
    "tasks": "node ./bin/mergeide.js tasks",
    "test": "node --test"
  },
  "keywords": [
    "mergeos",
    "mergeide",
    "vscode",
    "codex",
    "claude"
  ],
  "engines": {
    "node": ">=18.17.0",
    "vscode": "^1.90.0"
  },
  "activationEvents": [
    "onCommand:mergeide.showTasks",
    "onCommand:mergeide.runTask",
    "onCommand:mergeide.claimTask",
    "onCommand:mergeide.configureAiCli"
  ],
  "contributes": {
    "commands": [
      {
        "command": "mergeide.showTasks",
        "title": "MergeIDE: Show MergeOS Tasks"
      },
      {
        "command": "mergeide.runTask",
        "title": "MergeIDE: Run Task With AI CLI"
      },
      {
        "command": "mergeide.claimTask",
        "title": "MergeIDE: Claim Task"
      },
      {
        "command": "mergeide.configureAiCli",
        "title": "MergeIDE: Configure AI CLI"
      }
    ],
    "configuration": {
      "title": "MergeIDE",
      "properties": {
        "mergeide.mergeosUrl": {
          "type": "string",
          "default": "http://localhost:8080",
          "description": "MergeOS API base URL."
        },
        "mergeide.token": {
          "type": "string",
          "default": "",
          "description": "MergeOS auth token. Prefer the user settings file or environment variable for real tokens."
        },
        "mergeide.aiProvider": {
          "type": "string",
          "default": "codex",
          "enum": [
            "codex",
            "claude",
            "custom"
          ],
          "description": "AI CLI preset used by MergeIDE."
        },
        "mergeide.aiCommand": {
          "type": "string",
          "default": "",
          "description": "Command to launch the AI CLI. Empty uses the selected preset."
        },
        "mergeide.aiArgs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Arguments for the AI CLI. Supports {{prompt}}, {{promptFile}}, {{taskFile}}, and {{taskId}}."
        },
        "mergeide.workspaceRoot": {
          "type": "string",
          "default": "",
          "description": "Workspace where the AI CLI should run. Empty uses the current VS Code workspace."
        },
        "mergeide.workerId": {
          "type": "string",
          "default": "mergeide:local",
          "description": "Worker identity used when claiming MergeOS tasks."
        },
        "mergeide.agentType": {
          "type": "string",
          "default": "mergeide",
          "description": "Agent type sent to MergeOS for agent or hybrid tasks."
        },
        "mergeide.autoClaimAfterRun": {
          "type": "boolean",
          "default": false,
          "description": "Claim the task after the AI CLI exits successfully."
        }
      }
    }
  }
}
